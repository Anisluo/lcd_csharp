<UserControl x:Class="LCD_V2.Views.MetricsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ Metrics library ══════════════ -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                    <StackPanel>
                        <TextBlock Text="仪器指标库" Style="{StaticResource H3}"/>
                        <TextBlock Text="已保存的测量配置"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button x:Name="BtnNew" Content="+ 新建" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Padding="10,5" Click="BtnNew_Click"/>
                </Grid>
                <TextBox x:Name="TxtSearch" DockPanel.Dock="Top" Margin="14,4,14,10"
                         Text="搜索名称 / 仪器…" Foreground="{StaticResource TextSubtleBrush}"
                         GotFocus="TxtSearch_GotFocus"
                         TextChanged="TxtSearch_TextChanged"/>

                <Grid>
                    <!-- empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count, ElementName=LibraryList}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Ellipse Width="36" Height="36" Fill="#E5E7EB" HorizontalAlignment="Center"/>
                        <TextBlock Text="暂无指标配置" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="在右侧填写参数后 保存" FontSize="11"
                                   Foreground="{StaticResource TextSubtleBrush}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <ListBox x:Name="LibraryList"
                             BorderThickness="0" Background="Transparent" Padding="6,0"
                             SelectionChanged="Library_SelectionChanged"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavListItem}">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Summary}"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource GhostButton}"
                                            Content="×"
                                            Tag="{Binding}"
                                            Click="BtnDelete_Click"
                                            Padding="4,0" MinWidth="22" Height="22"
                                            FontSize="14"
                                            ToolTip="删除"
                                            Foreground="{StaticResource TextSubtleBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ══════════════ Editor ══════════════ -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <!-- header -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1"
                        Padding="18,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="新建 / 编辑仪器指标" Style="{StaticResource H3}"/>
                            <TextBlock Text="选择仪器、勾选参数、配置算法"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="重置" Margin="0,0,8,0" Click="BtnReset_Click"/>
                            <Button Content="保存到指标库" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- body -->
                <Grid Margin="18,14,18,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- basic info -->
                    <TextBlock Grid.Row="0" Text="基本信息" Style="{StaticResource Section}"/>
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="配置名称" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                            <TextBox x:Name="TxtName" Text="新指标" MinHeight="30"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="测量仪器" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                            <ComboBox x:Name="CmbInstrument" SelectedIndex="0" MinHeight="30"/>
                        </StackPanel>
                    </Grid>

                    <!-- params header strip -->
                    <Grid Grid.Row="2" Margin="0,0,0,6">
                        <TextBlock Text="参数与算法" Style="{StaticResource Section}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="全选" Click="BtnSelectAll_Click"  Padding="8,3" MinHeight="0" Margin="0,0,6,0"/>
                            <Button Content="全不选" Click="BtnSelectNone_Click" Padding="8,3" MinHeight="0"/>
                        </StackPanel>
                    </Grid>

                    <!-- params table -->
                    <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Background="White">
                        <DataGrid x:Name="ParamsGrid"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  BorderThickness="0"
                                  GridLinesVisibility="Horizontal"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="参数"
                                                    Binding="{Binding ParamName}"
                                                    IsReadOnly="True" Width="*"/>
                                <DataGridCheckBoxColumn Header="启用"
                                                        Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="80"/>
                                <DataGridComboBoxColumn x:Name="AlgoCol"
                                                        Header="算法"
                                                        SelectedItemBinding="{Binding Algorithm, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="160"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
