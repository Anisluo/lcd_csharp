<UserControl x:Class="LCD_V2.Views.Motion3DView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6FA">
    <Grid>
        <!-- Drag surface: transparent, spans the whole area; receives orbit drags. -->
        <Border x:Name="DragSurface" Background="Transparent" ClipToBounds="True">
            <Viewport3D x:Name="Viewport" ClipToBounds="True"/>
        </Border>

        <!-- Overlays: legend + reset-view button sit on top of the drag surface,
             so clicks on them don't start an orbit drag. -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12"
                Background="#E6FFFFFF"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Padding="10,8" IsHitTestVisible="True">
            <StackPanel>
                <TextBlock Text="3D 示意图" FontWeight="SemiBold" FontSize="12"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="TxtAxisState" Text="—"
                           FontSize="10.5" Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,4,0,0"/>
                <TextBlock Text="左键拖动旋转 · 滚轮缩放"
                           FontSize="10" Foreground="{StaticResource TextSubtleBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Button x:Name="BtnResetView" Content="复位视角"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12"
                Padding="10,4" FontSize="11" Click="BtnResetView_Click"/>
    </Grid>
</UserControl>
