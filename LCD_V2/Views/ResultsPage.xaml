<UserControl x:Class="LCD_V2.Views.ResultsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- filters row -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="条码" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="模板" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="全部" IsReadOnly="True"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="状态" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="全部" IsReadOnly="True"/>
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="时间范围" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Text="最近 7 天"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="导出 CSV" Margin="0,0,6,0"/>
                    <Button Content="查询" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- results grid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="16,14,16,10">
                    <TextBlock Text="测试记录" Style="{StaticResource H3}"/>
                    <TextBlock Text="共 0 条"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"/>
                </Grid>
                <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="1,1,1,1" Margin="16,0,16,16">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="测试 ID"  Width="80"/>
                        <DataGridTextColumn Header="条码"     Width="*"/>
                        <DataGridTextColumn Header="模板"     Width="*"/>
                        <DataGridTextColumn Header="L"        Width="80"/>
                        <DataGridTextColumn Header="x"        Width="80"/>
                        <DataGridTextColumn Header="y"        Width="80"/>
                        <DataGridTextColumn Header="CCT"      Width="80"/>
                        <DataGridTextColumn Header="状态"     Width="90"/>
                        <DataGridTextColumn Header="时间"     Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
