<UserControl x:Class="LCD_V2.Views.DevicesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Light meter -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="光度计" Style="{StaticResource H3}"/>
                        <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Right"
                                Background="{StaticResource DangerSoftBrush}" BorderBrush="{StaticResource DangerBrush}">
                            <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="BM7A" Style="{StaticResource MetricLabel}" Margin="0,12,0,0"/>
                    <TextBlock Text="Topcon BM-7A" FontWeight="SemiBold"/>
                    <TextBlock Text="COM: COM1 · 19200-8-N-1"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                    <Button Content="配置" Margin="0,14,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Power supply -->
            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="电源" Style="{StaticResource H3}"/>
                        <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Right"
                                Background="{StaticResource DangerSoftBrush}" BorderBrush="{StaticResource DangerBrush}">
                            <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="型号" Style="{StaticResource MetricLabel}" Margin="0,12,0,0"/>
                    <TextBlock Text="PowerM88" FontWeight="SemiBold"/>
                    <TextBlock Text="COM: COM3 · 9600-8-N-1"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                    <Button Content="配置" Margin="0,14,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Pattern generator -->
            <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="PG 图像发生器" Style="{StaticResource H3}"/>
                        <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Right"
                                Background="{StaticResource WarningSoftBrush}" BorderBrush="{StaticResource WarningBrush}">
                            <TextBlock Text="待机" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="型号" Style="{StaticResource MetricLabel}" Margin="0,12,0,0"/>
                    <TextBlock Text="NC816" FontWeight="SemiBold"/>
                    <TextBlock Text="IP: 192.168.0.100"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                    <Button Content="测试连接" Margin="0,14,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Motion controller -->
            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="运动平台" Style="{StaticResource H3}"/>
                        <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Right"
                                Background="{StaticResource DangerSoftBrush}" BorderBrush="{StaticResource DangerBrush}">
                            <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="型号" Style="{StaticResource MetricLabel}" Margin="0,12,0,0"/>
                    <TextBlock Text="MPC-08" FontWeight="SemiBold"/>
                    <TextBlock Text="PCI · 6 轴：X / Y / Z / U / V / Ball"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                    <Button Content="回零" Margin="0,14,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Camera -->
            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="相机" Style="{StaticResource H3}"/>
                        <Border Style="{StaticResource StatusPill}" HorizontalAlignment="Right"
                                Background="{StaticResource DangerSoftBrush}" BorderBrush="{StaticResource DangerBrush}">
                            <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="型号" Style="{StaticResource MetricLabel}" Margin="0,12,0,0"/>
                    <TextBlock Text="MV 工业相机" FontWeight="SemiBold"/>
                    <TextBlock Text="GigE · 1280×1024"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                    <Button Content="连接" Margin="0,14,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- Serial bus probe -->
            <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource Card}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="串口通讯测试" Style="{StaticResource H3}"/>
                    </Grid>
                    <TextBlock Text="可用端口" Style="{StaticResource MetricLabel}" Margin="0,12,0,4"/>
                    <TextBox Text="COM1, COM3, COM5" IsReadOnly="True"/>
                    <Button Content="打开测试工具" Style="{StaticResource PrimaryButton}" Margin="0,14,0,0" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
