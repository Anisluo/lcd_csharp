<UserControl x:Class="LCD_V2.Views.LogsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource Card}" Padding="0">
        <DockPanel>
            <!-- toolbar -->
            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="全部"   Margin="0,0,4,0" MinWidth="60"/>
                        <Button Content="信息"   Margin="0,0,4,0" MinWidth="60"/>
                        <Button Content="警告"   Margin="0,0,4,0" MinWidth="60"/>
                        <Button Content="错误"   Margin="0,0,4,0" MinWidth="60"
                                Style="{StaticResource PrimaryButton}"
                                Background="{StaticResource DangerBrush}"
                                BorderBrush="{StaticResource DangerBrush}"/>
                    </StackPanel>
                    <TextBox Grid.Column="2" Margin="16,0" MaxWidth="280" HorizontalAlignment="Left"/>
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button Content="清空" Margin="0,0,8,0"/>
                        <Button Content="导出" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- log body -->
            <ScrollViewer>
                <StackPanel Margin="16" x:Name="LogBody">
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="22:45:02" Foreground="{StaticResource TextSubtleBrush}" FontFamily="Consolas" FontSize="12" Width="78"/>
                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0">
                            <TextBlock Text="INFO" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="初始化完成，进入测试界面" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="22:45:02" Foreground="{StaticResource TextSubtleBrush}" FontFamily="Consolas" FontSize="12" Width="78"/>
                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0">
                            <TextBlock Text="INFO" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="检查设备连接" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="22:45:02" Foreground="{StaticResource TextSubtleBrush}" FontFamily="Consolas" FontSize="12" Width="78"/>
                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0">
                            <TextBlock Text="INFO" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="曝光时间:::  366139" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="22:45:02" Foreground="{StaticResource TextSubtleBrush}" FontFamily="Consolas" FontSize="12" Width="78"/>
                        <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0">
                            <TextBlock Text="WARN" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="MPC08 初始化失败：未识别到板卡" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="22:45:02" Foreground="{StaticResource TextSubtleBrush}" FontFamily="Consolas" FontSize="12" Width="78"/>
                        <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0">
                            <TextBlock Text="WARN" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="检测到光幕信号，停止运行" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3">
                        <TextBlock Text="22:45:02" Foreground="{StaticResource TextSubtleBrush}" FontFamily="Consolas" FontSize="12" Width="78"/>
                        <Border Background="{StaticResource DangerSoftBrush}" CornerRadius="3" Padding="5,1" Margin="0,0,8,0">
                            <TextBlock Text="ERROR" Foreground="{StaticResource DangerBrush}" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="BM7A.Init: Config 未设置，无法打开串口"
                                   Foreground="{StaticResource DangerBrush}" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
