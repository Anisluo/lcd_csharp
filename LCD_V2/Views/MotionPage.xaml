<UserControl x:Class="LCD_V2.Views.MotionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:LCD_V2.Views">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ Library ══════════════ -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                    <StackPanel>
                        <TextBlock Text="平台库" Style="{StaticResource H3}"/>
                        <TextBlock Text="已保存的运动平台配置"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button x:Name="BtnNew" Content="+ 新建" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Padding="10,5" Click="BtnNew_Click"/>
                </Grid>
                <TextBox x:Name="TxtSearch" DockPanel.Dock="Top" Margin="14,4,14,10"
                         Text="搜索名称 / 算法…" Foreground="{StaticResource TextSubtleBrush}"
                         GotFocus="TxtSearch_GotFocus"
                         TextChanged="TxtSearch_TextChanged"/>

                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count, ElementName=LibraryList}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Ellipse Width="36" Height="36" Fill="#E5E7EB" HorizontalAlignment="Center"/>
                        <TextBlock Text="暂无平台配置" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="在右侧填写参数后 保存" FontSize="11"
                                   Foreground="{StaticResource TextSubtleBrush}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <ListBox x:Name="LibraryList"
                             BorderThickness="0" Background="Transparent" Padding="6,0"
                             SelectionChanged="Library_SelectionChanged"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavListItem}">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Summary}"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource GhostButton}"
                                            Content="×"
                                            Tag="{Binding}"
                                            Click="BtnDelete_Click"
                                            Padding="4,0" MinWidth="22" Height="22"
                                            FontSize="14"
                                            ToolTip="删除"
                                            Foreground="{StaticResource TextSubtleBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ══════════════ Editor ══════════════ -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1"
                        Padding="18,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="新建 / 编辑运动平台" Style="{StaticResource H3}"/>
                            <TextBlock Text="选择算法、配置 5 个轴的速度与脉冲参数"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="重置" Margin="0,0,8,0" Click="BtnReset_Click"/>
                            <Button Content="保存到平台库" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="18,14,18,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- basic info -->
                        <TextBlock Grid.Row="0" Text="基本信息" Style="{StaticResource Section}"/>
                        <Grid Grid.Row="1" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="14"/>
                                <ColumnDefinition Width="300"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="配置名称" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <TextBox x:Name="TxtName" Text="新平台" MinHeight="30"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="运动算法" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <ComboBox x:Name="CmbAlgorithm" SelectedIndex="0" MinHeight="30"/>
                            </StackPanel>
                        </Grid>

                        <!-- axis section header -->
                        <Grid Grid.Row="2" Margin="0,0,0,6">
                            <TextBlock Text="5 轴参数" Style="{StaticResource Section}" VerticalAlignment="Center"/>
                            <TextBlock Text="速度单位: X/Y/Z mm/s, U/V °/s"
                                       Foreground="{StaticResource TextSubtleBrush}" FontSize="11"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- axis table -->
                        <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Background="White" MinHeight="220">
                            <DataGrid x:Name="AxesGrid"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      RowHeight="34"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="轴"
                                                        Binding="{Binding AxisName}"
                                                        IsReadOnly="True" Width="50"/>
                                    <DataGridTextColumn Header="轴代号"
                                                        Binding="{Binding AxisCode, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="80"/>
                                    <DataGridTemplateColumn Header="插补轴代号" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding InterpolateCode, UpdateSourceTrigger=PropertyChanged}"
                                                         IsEnabled="{Binding Interpolate}"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         VerticalContentAlignment="Center"
                                                         Padding="6,0"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridCheckBoxColumn Header="启用"
                                                            Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="60"/>
                                    <DataGridTextColumn Header="高速"
                                                        Binding="{Binding HighSpeed, StringFormat='0.###', UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="中速"
                                                        Binding="{Binding MidSpeed,  StringFormat='0.###', UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="低速"
                                                        Binding="{Binding LowSpeed,  StringFormat='0.###', UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="加速时间 (ms)"
                                                        Binding="{Binding AccelTimeMs, StringFormat='0', UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="脉冲当量"
                                                        Binding="{Binding PulseUnit, StringFormat='0.####', UpdateSourceTrigger=PropertyChanged}"
                                                        Width="*"/>
                                    <DataGridCheckBoxColumn Header="反向"
                                                            Binding="{Binding Invert, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="60"/>
                                    <DataGridCheckBoxColumn Header="插补"
                                                            Binding="{Binding Interpolate, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- 3D schematic preview — axes dim when disabled in the table above -->
                        <Grid Grid.Row="4" Margin="0,18,0,6">
                            <TextBlock Text="3D 示意图" Style="{StaticResource Section}" VerticalAlignment="Center"/>
                            <Button x:Name="BtnSim" Content="开始仿真"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Padding="12,5" Click="BtnSim_Click"/>
                        </Grid>
                        <Border Grid.Row="5"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Background="White"
                                MinHeight="320">
                            <views:Motion3DView x:Name="Preview3D"/>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
