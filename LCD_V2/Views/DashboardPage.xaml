<UserControl x:Class="LCD_V2.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- metric strip -->
                <RowDefinition Height="Auto"/>   <!-- middle row: cam + run/stop + log preview -->
                <RowDefinition Height="Auto"/>   <!-- recent runs table -->
            </Grid.RowDefinitions>

            <!-- ═════════ position metrics ═════════ -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="X 轴 (mm)" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="0.00" Style="{StaticResource MetricValue}"/>
                        <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontSize="11" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Y 轴 (mm)" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="0.00" Style="{StaticResource MetricValue}"/>
                        <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontSize="11" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Z 轴 (mm)" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="0.00" Style="{StaticResource MetricValue}"/>
                        <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontSize="11" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource MetricCard}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="U 轴 (°)" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="0.00" Style="{StaticResource MetricValue}"/>
                        <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontSize="11" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="4" Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="V 轴 (°)" Style="{StaticResource MetricLabel}"/>
                        <TextBlock Text="0.00" Style="{StaticResource MetricValue}"/>
                        <TextBlock Text="未连接" Foreground="{StaticResource DangerBrush}" FontSize="11" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═════════ camera + run controls + log preview ═════════ -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- camera + jog controls card -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,16,0" Padding="16,14,16,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- title row -->
                            <RowDefinition Height="*"/>     <!-- camera -->
                            <RowDefinition Height="Auto"/>  <!-- jog controls -->
                        </Grid.RowDefinitions>

                        <!-- title + status -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="监视画面 / 手动调节" Style="{StaticResource H3}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Border Style="{StaticResource StatusPill}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="无信号" Margin="6,0,0,0" Foreground="{StaticResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- camera viewport -->
                        <Border Grid.Row="1" Background="#0B0F19" CornerRadius="6" MinHeight="280">
                            <Grid>
                                <!-- crosshair overlay -->
                                <Line X1="0" Y1="0.5" X2="1" Y2="0.5"
                                      Stroke="#9F1239" StrokeThickness="0.5"
                                      Stretch="Fill"/>
                                <Line X1="0.5" Y1="0" X2="0.5" Y2="1"
                                      Stroke="#9F1239" StrokeThickness="0.5"
                                      Stretch="Fill"/>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Ellipse Width="40" Height="40" Fill="#1F2937" HorizontalAlignment="Center"/>
                                    <TextBlock Text="等待相机连接"
                                               Foreground="#9CA3AF"
                                               Margin="0,10,0,0"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="检查设备设置 →"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                                <!-- camera meta strip -->
                                <Border VerticalAlignment="Bottom" Background="#80000000" Padding="10,6">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="相机:" Foreground="#9CA3AF" FontSize="11"/>
                                            <TextBlock Text="MV 工业相机" Foreground="#E5E7EB" FontSize="11" FontWeight="SemiBold" Margin="4,0,14,0"/>
                                            <TextBlock Text="曝光:" Foreground="#9CA3AF" FontSize="11"/>
                                            <TextBlock Text="366139 μs" Foreground="#E5E7EB" FontSize="11" FontWeight="SemiBold" Margin="4,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="1280 × 1024"
                                                   Foreground="#9CA3AF" FontSize="11"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ════════ JOG CONTROLS ════════ -->
                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- XY directional pad -->
                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                <TextBlock Text="XY 移动" Style="{StaticResource Section}"/>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="Y+">
                                        <Path Data="{StaticResource IconArrowUp}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="X-">
                                        <Path Data="{StaticResource IconArrowLeft}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource JogOriginButton}" Width="38" Height="34" Margin="1" ToolTip="回零">
                                        <Path Data="{StaticResource IconCrosshair}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="X+">
                                        <Path Data="{StaticResource IconArrowRight}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                    <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="Y-">
                                        <Path Data="{StaticResource IconArrowDown}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Z column -->
                            <StackPanel Grid.Column="1" Margin="0,0,16,0">
                                <TextBlock Text="Z 轴" Style="{StaticResource Section}"/>
                                <StackPanel>
                                    <Button Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="Z 上升">
                                        <Path Data="{StaticResource IconArrowUp}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                    <Border Height="36"/>
                                    <Button Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="Z 下降">
                                        <Path Data="{StaticResource IconArrowDown}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>

                            <!-- UV rotation -->
                            <StackPanel Grid.Column="2" Margin="0,0,16,0">
                                <TextBlock Text="UV 旋转" Style="{StaticResource Section}"/>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="U 逆时针">
                                        <Path Data="{StaticResource IconRotateCcw}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.6" Fill="Transparent"/>
                                    </Button>
                                    <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="U 顺时针">
                                        <Path Data="{StaticResource IconRotateCw}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.6" Fill="Transparent"/>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="V 前倾">
                                        <Path Data="{StaticResource IconTiltUp}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                    <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource JogButton}" Width="38" Height="34" Margin="1" ToolTip="V 后倾">
                                        <Path Data="{StaticResource IconTiltDown}" Stretch="Uniform" Width="14" Height="14"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Step size -->
                            <StackPanel Grid.Column="3" Margin="0,0,16,0">
                                <TextBlock Text="步长" Style="{StaticResource Section}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Text="1.00" Width="72" VerticalContentAlignment="Center"/>
                                    <ComboBox SelectedIndex="0" Width="56" Margin="4,0,0,0" VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="mm"/>
                                        <ComboBoxItem Content="°"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Speed selector -->
                            <StackPanel Grid.Column="5" HorizontalAlignment="Right">
                                <TextBlock Text="速度" Style="{StaticResource Section}"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton x:Name="SpeedLow"  GroupName="Speed" Style="{StaticResource SpeedToggle}" ToolTip="低速" Margin="0,0,4,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconSpeed1}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                  Stretch="Uniform" Width="14" Height="14"/>
                                            <TextBlock Text="低" Margin="4,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton x:Name="SpeedMid"  GroupName="Speed" Style="{StaticResource SpeedToggle}" ToolTip="中速" Margin="0,0,4,0" IsChecked="True">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconSpeed2}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                  Stretch="Uniform" Width="14" Height="14"/>
                                            <TextBlock Text="中" Margin="4,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </RadioButton>
                                    <RadioButton x:Name="SpeedHigh" GroupName="Speed" Style="{StaticResource SpeedToggle}" ToolTip="高速">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconSpeed3}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                                                  Stretch="Uniform" Width="14" Height="14"/>
                                            <TextBlock Text="高" Margin="4,0,0,0" FontSize="11" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </RadioButton>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- run controls + mini log -->
                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="执行控制" Style="{StaticResource H3}" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource SuccessButton}" MinHeight="56" Margin="0,0,6,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconPlay}" Fill="White"
                                              Stretch="Uniform" Width="14" Height="14"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="开始" FontSize="14" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Style="{StaticResource DangerButton}" MinHeight="56" Margin="6,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconStop}" Fill="White"
                                              Stretch="Uniform" Width="14" Height="14"
                                              VerticalAlignment="Center"/>
                                        <TextBlock Text="急停" FontSize="14" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <!-- 返回零点 (motor homing) — primary secondary action, styled to sit
                                 between the Start/EStop duo and the quick measurement actions. -->
                            <Button MinHeight="40" Margin="0,12,0,0" HorizontalAlignment="Stretch"
                                    BorderBrush="{StaticResource AccentBrush}"
                                    Foreground="{StaticResource AccentBrush}"
                                    Background="{StaticResource AccentSoftBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconHome}"
                                          Stretch="Uniform" Width="14" Height="14"
                                          Fill="{StaticResource AccentBrush}"
                                          VerticalAlignment="Center"/>
                                    <TextBlock Text="返回零点" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Separator Margin="0,14"/>

                            <TextBlock Text="快速操作" Style="{StaticResource Section}"/>
                            <Button Content="单点测量" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                            <Button Content="光谱测量" Margin="0,0,0,6" HorizontalAlignment="Stretch"/>
                            <Button Content="模板测试" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="最近事件" Style="{StaticResource H3}"/>
                                <Button Content="查看全部" Style="{StaticResource GhostButton}"
                                        HorizontalAlignment="Right" FontSize="12" Padding="4,2" MinWidth="0"/>
                            </Grid>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="系统初始化完成" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource WarningBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="MPC08 初始化失败" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource DangerBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="BM7A Config 未设置" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="6" Height="6" Fill="{StaticResource TextSubtleBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="检测到光幕信号，停止运行" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ═════════ current test: template ↔ results ═════════ -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <!-- header strip -->
                    <Grid Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="当前测试" Style="{StaticResource H3}"/>
                            <Rectangle Width="1" Height="18" Fill="{StaticResource DividerBrush}" Margin="14,0"/>
                            <TextBlock Text="模板" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                            <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="4"
                                    Padding="8,2" Margin="6,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="13 点对角" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="条码" Foreground="{StaticResource TextMutedBrush}" Margin="14,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="LCD-0421-001" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="进度" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="4" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="15"/>
                                <Run Text=" / 13" Foreground="{StaticResource TextMutedBrush}"/>
                            </TextBlock>
                            <ProgressBar Width="200" Height="6" Margin="10,0,0,0" Minimum="0" Maximum="13" Value="4"
                                         Background="{StaticResource DividerBrush}" Foreground="{StaticResource AccentBrush}"
                                         BorderThickness="0"/>
                        </StackPanel>
                    </Grid>

                    <!-- two-column linked tables -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: template points -->
                        <Border Grid.Column="0" Background="White"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#F9FAFB"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="12,8">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="模板点位" FontWeight="SemiBold"/>
                                            <TextBlock Text="13 点" Margin="8,0,0,0"
                                                       Foreground="{StaticResource TextSubtleBrush}"/>
                                        </StackPanel>
                                        <TextBlock Text="→ 移动到下一条即执行"
                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                   FontSize="11"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <DataGrid x:Name="TemplateGrid"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          IsReadOnly="True" HeadersVisibility="Column"
                                          BorderThickness="0"
                                          MaxHeight="240"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#"       Binding="{Binding No}"     Width="50"/>
                                        <DataGridTextColumn Header="X (mm)"  Binding="{Binding X, StringFormat='0.00'}" Width="*"/>
                                        <DataGridTextColumn Header="Y (mm)"  Binding="{Binding Y, StringFormat='0.00'}" Width="*"/>
                                        <DataGridTextColumn Header="Z (mm)"  Binding="{Binding Z, StringFormat='0.00'}" Width="*"/>
                                        <DataGridTextColumn Header="U (°)"   Binding="{Binding U, StringFormat='0.00'}" Width="*"/>
                                        <DataGridTextColumn Header="V (°)"   Binding="{Binding V, StringFormat='0.00'}" Width="*"/>
                                        <DataGridTextColumn Header="备注"    Binding="{Binding Remark}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- Right: test results -->
                        <Border Grid.Column="2" Background="White"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#F9FAFB"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="12,8">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="测试结果" FontWeight="SemiBold"/>
                                            <Border Background="{StaticResource SuccessSoftBrush}" CornerRadius="8" Padding="6,1" Margin="8,0,0,0">
                                                <TextBlock Text="3 已采" Foreground="{StaticResource SuccessBrush}" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                            <Border Background="{StaticResource WarningSoftBrush}" CornerRadius="8" Padding="6,1" Margin="6,0,0,0">
                                                <TextBlock Text="1 进行中" Foreground="{StaticResource WarningBrush}" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                        <Button Content="导出 CSV" HorizontalAlignment="Right" Padding="8,3" MinHeight="0"/>
                                    </Grid>
                                </Border>
                                <DataGrid x:Name="ResultGrid"
                                          AutoGenerateColumns="False" CanUserAddRows="False"
                                          IsReadOnly="True" HeadersVisibility="Column"
                                          BorderThickness="0"
                                          MaxHeight="240"
                                          SelectionMode="Single"
                                          GridLinesVisibility="Horizontal">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#"    Binding="{Binding No}"     Width="50"/>
                                        <DataGridTextColumn Header="L"    Binding="{Binding L,   StringFormat='0.0',   TargetNullValue='—'}" Width="*"/>
                                        <DataGridTextColumn Header="x"    Binding="{Binding Cx,  StringFormat='0.0000', TargetNullValue='—'}" Width="*"/>
                                        <DataGridTextColumn Header="y"    Binding="{Binding Cy,  StringFormat='0.0000', TargetNullValue='—'}" Width="*"/>
                                        <DataGridTextColumn Header="CCT"  Binding="{Binding CCT, StringFormat='0',      TargetNullValue='—'}" Width="*"/>
                                        <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="70"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
