<UserControl x:Class="LCD_V2.Views.TemplatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Templates list -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="16,14,16,10">
                    <TextBlock Text="模板库" Style="{StaticResource H3}"/>
                    <Button Content="+ 新建" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Padding="10,5"/>
                </Grid>
                <TextBox DockPanel.Dock="Top" Margin="16,0,16,12" Text="搜索模板…" Foreground="{StaticResource TextSubtleBrush}"/>
                <ListBox BorderThickness="0" Background="Transparent" Padding="8,0" ItemContainerStyle="{StaticResource NavListItem}">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavListItem}">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Style>
                    </ListBox.Resources>
                    <ListBoxItem>
                        <StackPanel>
                            <TextBlock Text="5 点模板"  FontWeight="SemiBold"/>
                            <TextBlock Text="5 个测试点 · 中心 + 四角" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel>
                            <TextBlock Text="9 点模板"  FontWeight="SemiBold"/>
                            <TextBlock Text="3×3 均布点" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel>
                            <TextBlock Text="13 点模板" FontWeight="SemiBold"/>
                            <TextBlock Text="中心 + 对角线 + 边缘" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel>
                            <TextBlock Text="13 点对角" FontWeight="SemiBold"/>
                            <TextBlock Text="对角线定位点" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <StackPanel>
                            <TextBlock Text="自定义 17 点" FontWeight="SemiBold"/>
                            <TextBlock Text="用户自定义" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Editor area -->
        <Border Grid.Column="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="模板编辑" Style="{StaticResource H3}"/>
                <TextBlock Text="选择左侧模板进行编辑，或新建模板。"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,20"/>

                <TextBlock Text="基本信息" Style="{StaticResource Section}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="模板名称" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="13 点对角"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="点阵类型" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                        <TextBox Text="13_POINT_DIAG" IsReadOnly="True"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="点位数据" Style="{StaticResource Section}"/>
                <DataGrid Height="300" AutoGenerateColumns="False" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"       Width="50"/>
                        <DataGridTextColumn Header="X (mm)"  Width="*"/>
                        <DataGridTextColumn Header="Y (mm)"  Width="*"/>
                        <DataGridTextColumn Header="Z (mm)"  Width="*"/>
                        <DataGridTextColumn Header="U (°)"   Width="*"/>
                        <DataGridTextColumn Header="V (°)"   Width="*"/>
                        <DataGridTextColumn Header="备注"    Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="取消" Margin="0,0,8,0"/>
                    <Button Content="保存模板" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
