<UserControl x:Class="LCD_V2.Views.TemplatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ Templates library ══════════════
             Shows saved template instances (Name + config type + dims).
             Populated by Save 保存模板 in the right-hand editor. -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                    <StackPanel>
                        <TextBlock Text="模板库" Style="{StaticResource H3}"/>
                        <TextBlock Text="已保存的测试模板"
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button x:Name="BtnNew" Content="+ 新建" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Padding="10,5" Click="BtnNew_Click"/>
                </Grid>
                <TextBox DockPanel.Dock="Top" Margin="14,4,14,10"
                         Text="搜索模板…" Foreground="{StaticResource TextSubtleBrush}"/>

                <Grid>
                    <!-- empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="20">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Items.Count, ElementName=LibraryList}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Ellipse Width="36" Height="36" Fill="#E5E7EB" HorizontalAlignment="Center"/>
                        <TextBlock Text="暂无模板" Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="在右侧填写参数后 保存模板" FontSize="11"
                                   Foreground="{StaticResource TextSubtleBrush}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <ListBox x:Name="LibraryList"
                             BorderThickness="0" Background="Transparent" Padding="6,0"
                             SelectionChanged="Library_SelectionChanged"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavListItem}">
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Summary}"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource GhostButton}"
                                            Content="×"
                                            Tag="{Binding}"
                                            Click="BtnDelete_Click"
                                            Padding="4,0" MinWidth="22" Height="22"
                                            FontSize="14"
                                            ToolTip="删除模板"
                                            Foreground="{StaticResource TextSubtleBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ══════════════ Editor ══════════════ -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
            <DockPanel>
                <!-- editor header -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1"
                        Padding="18,14">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="新建 / 编辑模板" Style="{StaticResource H3}"/>
                            <TextBlock Text="选择点阵配置、填入参数，保存后入库"
                                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="重置" Margin="0,0,8,0" Click="BtnReset_Click"/>
                            <Button Content="保存到模板库" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- body: 2 columns (form | preview) -->
                <Grid Margin="18,14,18,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ═══ left: form ═══ -->
                    <StackPanel Grid.Column="0">
                        <!-- reference image (auto-loaded based on 点阵配置 selection) -->
                        <TextBlock Text="参考图片" Style="{StaticResource Section}"/>
                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="6" Background="#F9FAFB" Height="180">
                            <Grid>
                                <Image x:Name="RefImage" Stretch="Uniform" Margin="4"/>
                                <StackPanel x:Name="RefPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Ellipse Width="40" Height="40" Fill="#E5E7EB" HorizontalAlignment="Center"/>
                                    <TextBlock Text="该配置暂无内置参考图" Foreground="{StaticResource TextMutedBrush}"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- basic info -->
                        <TextBlock Text="基本信息" Style="{StaticResource Section}" Margin="0,18,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="模板名称" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <!-- Name is only captured at Save time; don't trigger Regenerate on every keystroke
                                     (Chinese IME composition was firing TextChanged rapidly → UI jank). -->
                                <TextBox x:Name="TxtName" Text="13 点对角"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="点阵配置" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <ComboBox x:Name="CmbType" SelectedIndex="3" SelectionChanged="Type_Changed">
                                    <ComboBoxItem Content="5 点"/>
                                    <ComboBoxItem Content="9 点"/>
                                    <ComboBoxItem Content="13 点"/>
                                    <ComboBoxItem Content="13 点对角"/>
                                    <ComboBoxItem Content="17 点"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- product dimensions -->
                        <TextBlock Text="产品尺寸 (mm)" Style="{StaticResource Section}" Margin="0,16,0,0"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="长 H" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <TextBox x:Name="TxtH" Text="300.00" TextChanged="AnyParam_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="宽 V" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <TextBox x:Name="TxtV" Text="200.00" TextChanged="AnyParam_Changed"/>
                            </StackPanel>
                        </Grid>

                        <!-- ABCD + unit toggle -->
                        <Grid Margin="0,16,0,0">
                            <TextBlock Text="参数 A / B / C / D" Style="{StaticResource Section}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <RadioButton x:Name="RadioPct" GroupName="UnitMode" Content="百分比 (%)"
                                             IsChecked="True" Margin="0,0,12,0" Checked="Unit_Changed"/>
                                <RadioButton x:Name="RadioMm"  GroupName="UnitMode" Content="毫米 (mm)" Checked="Unit_Changed"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="A (X 边距)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <TextBox x:Name="TxtA" Text="10" TextChanged="AnyParam_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="B (Y 边距)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <TextBox x:Name="TxtB" Text="10" TextChanged="AnyParam_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="C (X 内环)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <TextBox x:Name="TxtC" Text="25" TextChanged="AnyParam_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="D (Y 内环)" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" FontSize="12"/>
                                <TextBox x:Name="TxtD" Text="25" TextChanged="AnyParam_Changed"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="TxtHint" Margin="0,10,0,0" FontSize="11"
                                   Foreground="{StaticResource TextSubtleBrush}"
                                   Text="提示：13 点对角使用固定 10% 网格，A/B/C/D 不参与计算。"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- ═══ right: points preview — schematic on top, list below ═══ -->
                    <Border Grid.Column="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Background="White">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- header -->
                                <RowDefinition Height="Auto"/>   <!-- schematic -->
                                <RowDefinition Height="Auto"/>   <!-- divider -->
                                <RowDefinition Height="*"/>      <!-- list -->
                            </Grid.RowDefinitions>

                            <!-- header -->
                            <Border Grid.Row="0" Background="#F9FAFB"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                                    Padding="12,8">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="点位示意图" FontWeight="SemiBold"/>
                                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="8" Padding="6,1" Margin="8,0,0,0">
                                            <TextBlock x:Name="TxtCount" Text="13 个"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock x:Name="TxtDims" Margin="10,0,0,0"
                                                   Foreground="{StaticResource TextSubtleBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="点击点位查看坐标"
                                               Foreground="{StaticResource TextSubtleBrush}" FontSize="11"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- schematic — fixed height, product aspect preserved by Viewbox -->
                            <Border Grid.Row="1" Height="300" Background="#FAFBFD" Padding="16">
                                <Grid>
                                    <Viewbox Stretch="Uniform">
                                        <Canvas x:Name="SchematicCanvas" Background="Transparent"/>
                                    </Viewbox>
                                    <!-- selected point callout, positioned top-right inside the schematic area -->
                                    <Border x:Name="CalloutBox"
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Background="{StaticResource TitleBarBrush}"
                                            CornerRadius="4" Padding="10,6" Margin="0,0,4,0"
                                            Visibility="Collapsed">
                                        <StackPanel>
                                            <TextBlock x:Name="CalloutTitle"
                                                       Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                            <TextBlock x:Name="CalloutBody"
                                                       Foreground="#D1D5DB" FontSize="10.5" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- divider with title -->
                            <Border Grid.Row="2" Background="#F9FAFB"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,1,0,1"
                                    Padding="12,6">
                                <TextBlock Text="点位列表" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                            </Border>

                            <!-- list — syncs with schematic via selection -->
                            <DataGrid Grid.Row="3" x:Name="PointsGrid"
                                      AutoGenerateColumns="False" CanUserAddRows="False"
                                      IsReadOnly="True" HeadersVisibility="Column"
                                      BorderThickness="0"
                                      GridLinesVisibility="Horizontal"
                                      SelectionMode="Single"
                                      SelectionChanged="PointsGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#"       Binding="{Binding Id}"  Width="50"/>
                                    <DataGridTextColumn Header="X (mm)"  Binding="{Binding XMm, StringFormat='0.00'}" Width="*"/>
                                    <DataGridTextColumn Header="Y (mm)"  Binding="{Binding YMm, StringFormat='0.00'}" Width="*"/>
                                    <DataGridTextColumn Header="X (%)"   Binding="{Binding XPct, StringFormat='0.0'}" Width="*"/>
                                    <DataGridTextColumn Header="Y (%)"   Binding="{Binding YPct, StringFormat='0.0'}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
