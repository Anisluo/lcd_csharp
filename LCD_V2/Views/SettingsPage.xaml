<UserControl x:Class="LCD_V2.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
            <StackPanel Margin="8">
                <TextBlock Text="设置分类" Style="{StaticResource Section}" Margin="8,10,8,6"/>
                <ListBox BorderThickness="0" Background="Transparent" SelectedIndex="0"
                         ItemContainerStyle="{StaticResource NavListItem}">
                    <ListBox.Resources>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavListItem}">
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Style>
                    </ListBox.Resources>
                    <ListBoxItem Content="通讯 / 串口"/>
                    <ListBoxItem Content="测试设备"/>
                    <ListBoxItem Content="运动参数"/>
                    <ListBoxItem Content="视角 / 标定"/>
                    <ListBoxItem Content="数据格式"/>
                    <ListBoxItem Content="日志选项"/>
                    <ListBoxItem Content="语言 / 界面"/>
                </ListBox>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock Text="通讯 / 串口" Style="{StaticResource H2}"/>
                    <TextBlock Text="设置各设备的串口通讯参数。修改后点击保存应用到配置文件。"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,24"/>

                    <TextBlock Text="光度计 (BM7A)" Style="{StaticResource Section}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="端口"     Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="COM1"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="波特率"   Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="19200"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="数据位"   Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="8"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="校验 / 停止位" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="None / 1"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="电源 (PowerM88)" Style="{StaticResource Section}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="端口"   Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="COM3"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="波特率" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Text="9600"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                        <Button Content="恢复默认" Margin="0,0,8,0"/>
                        <Button Content="保存" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
