<!--
    Modern default styles — Phase 6.

    All styles are *implicit* (no x:Key), so they apply automatically to
    every control of the targeted type. Keyed styles in Buttons.xaml etc
    continue to work unchanged because consumers reference them explicitly.

    Palette (from Themes/BrushesColors.xaml):
      PrimaryBrush    = #326cf3 (accent blue)
      BorderBrush     = #e0e0e0 (neutral border)
      RegionBrush     = #ffffff (card/control fill)
      BackgroundBrush = #eeeeee (window fill)
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <system:Double x:Key="ModernFontSize">13</system:Double>
    <FontFamily    x:Key="ModernFontFamily">Segoe UI, Microsoft YaHei UI, 微软雅黑</FontFamily>
    <CornerRadius  x:Key="ModernCornerRadius">4</CornerRadius>
    <Thickness     x:Key="ModernControlPadding">10,5</Thickness>

    <!-- Primary accent (reused from BrushesColors.xaml if present) -->
    <SolidColorBrush x:Key="ModernAccentBrush"     Color="#326cf3"/>
    <SolidColorBrush x:Key="ModernAccentHoverBrush" Color="#4a81f5"/>
    <SolidColorBrush x:Key="ModernAccentSoftBrush" Color="#EEF3FF"/>
    <SolidColorBrush x:Key="ModernBorderBrush"     Color="#D8DDE4"/>
    <SolidColorBrush x:Key="ModernBorderHoverBrush" Color="#A8B2BF"/>
    <SolidColorBrush x:Key="ModernHoverBrush"      Color="#F3F5F8"/>
    <SolidColorBrush x:Key="ModernPressedBrush"    Color="#E6EAF0"/>
    <SolidColorBrush x:Key="ModernTextBrush"       Color="#222831"/>
    <SolidColorBrush x:Key="ModernMutedTextBrush"  Color="#6B7280"/>
    <SolidColorBrush x:Key="ModernAltRowBrush"     Color="#F7F9FC"/>

    <!-- Additional palette for redesign -->
    <SolidColorBrush x:Key="ModernCanvasBrush"      Color="#F5F7FA"/>  <!-- app background -->
    <SolidColorBrush x:Key="ModernCardBrush"        Color="#FFFFFF"/>  <!-- card fill -->
    <SolidColorBrush x:Key="ModernDividerBrush"     Color="#EAEDF2"/>
    <SolidColorBrush x:Key="ModernSuccessBrush"     Color="#2DB84D"/>
    <SolidColorBrush x:Key="ModernSuccessSoftBrush" Color="#E9F7EC"/>
    <SolidColorBrush x:Key="ModernDangerBrush"      Color="#DB3340"/>
    <SolidColorBrush x:Key="ModernDangerSoftBrush"  Color="#FCEAEC"/>
    <SolidColorBrush x:Key="ModernWarningBrush"     Color="#E9AF20"/>
    <SolidColorBrush x:Key="ModernWarningSoftBrush" Color="#FDF5E4"/>

    <!-- ===== Card: primary content container ===== -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource ModernCardBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ===== SectionTitle: small-caps header for panel groupings ===== -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"     Value="11"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="{StaticResource ModernMutedTextBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="Margin"       Value="0,0,0,6"/>
    </Style>

    <!-- ===== MetricCard: used to show axis readouts, numeric sensors =====
         Apply to a Border; put a StackPanel inside with two TextBlocks:
         1) styled as "MetricLabel", 2) styled as "MetricValue".           -->
    <Style x:Key="MetricCard" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource ModernCardBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="6"/>
        <Setter Property="Padding"          Value="10,6"/>
        <Setter Property="MinWidth"         Value="92"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="MetricLabel" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource ModernMutedTextBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="MetricValue" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="Margin"     Value="0,2,0,0"/>
    </Style>

    <!-- ===== StatusPill: for status bar items with a colored dot + label =====
         Apply to a Border around StackPanel. Default is neutral; override
         DotBrush via setter on inner Ellipse if needed.                    -->
    <Style x:Key="StatusPill" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource ModernCanvasBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="CornerRadius"     Value="12"/>
        <Setter Property="Padding"          Value="10,3"/>
        <Setter Property="Margin"           Value="0,0,6,0"/>
    </Style>

    <!-- ===== IconActionButton: flat toolbar icon with optional label =====
         Use as Style={StaticResource IconActionButton}                     -->
    <Style x:Key="IconActionButton" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Padding"          Value="8,4"/>
        <Setter Property="MinWidth"         Value="36"/>
        <Setter Property="MinHeight"        Value="32"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Foreground"       Value="{StaticResource ModernMutedTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor"  Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== PrimaryActionButton: filled accent button (CTAs) ===== -->
    <Style x:Key="PrimaryActionButton" TargetType="Button">
        <Setter Property="Background"       Value="{StaticResource ModernAccentBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource ModernAccentBrush}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Foreground"       Value="White"/>
        <Setter Property="Padding"          Value="14,6"/>
        <Setter Property="MinHeight"        Value="30"/>
        <Setter Property="MinWidth"         Value="84"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FontWeight"       Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernAccentHoverBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernAccentHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2856C7"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== DangerActionButton: red filled (emergency stop etc) ===== -->
    <Style x:Key="DangerActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
        <Setter Property="Background"  Value="{StaticResource ModernDangerBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModernDangerBrush}"/>
    </Style>

    <!-- ===== SuccessActionButton: green filled (start test) ===== -->
    <Style x:Key="SuccessActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
        <Setter Property="Background"  Value="{StaticResource ModernSuccessBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModernSuccessBrush}"/>
    </Style>

    <!-- ===== CircularIconButton: round 48/56px colored buttons (run/stop) ===== -->
    <Style x:Key="CircularIconButton" TargetType="Button">
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Padding"          Value="10"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse x:Name="Bd"
                                 Fill="{TemplateBinding Background}"
                                 Stroke="{TemplateBinding BorderBrush}"
                                 StrokeThickness="{TemplateBinding BorderThickness}"
                                 SnapsToDevicePixels="True"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Window ===== -->
    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType"/>
    </Style>

    <Style TargetType="UserControl">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
    </Style>

    <!-- ===== Button ===== -->
    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="Background" Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="{StaticResource ModernControlPadding}"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="MinWidth"  Value="64"/>
        <Setter Property="Cursor"    Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            CornerRadius="{StaticResource ModernCornerRadius}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernHoverBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernBorderHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDefault" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernAccentBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernAccentBrush}"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsDefault" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernAccentHoverBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernAccentHoverBrush}"/>
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor"  Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== TextBox ===== -->
    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,3"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{StaticResource ModernAccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            CornerRadius="{StaticResource ModernCornerRadius}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernBorderHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernAccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ComboBox ===== -->
    <Style TargetType="ToggleButton" x:Key="ModernComboBoxToggleButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="ClickMode" Value="Press"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent">
                        <Path HorizontalAlignment="Center" VerticalAlignment="Center"
                              Fill="{StaticResource ModernMutedTextBrush}"
                              Data="M 0 0 L 4 4 L 8 0 Z"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Bd"
                                CornerRadius="{StaticResource ModernCornerRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="22"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False"/>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxToggleButton}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="{TemplateBinding Padding}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Visibility="Collapsed"
                                     VerticalContentAlignment="Center"/>
                        </Grid>
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="White"
                                    BorderBrush="{StaticResource ModernBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource ModernCornerRadius}"
                                    Margin="0,2,0,0">
                                <ScrollViewer>
                                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernBorderHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernAccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernAccentSoftBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernAccentSoftBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource ModernAccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== CheckBox ===== -->
    <Style TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Bx"
                                Width="16" Height="16"
                                CornerRadius="3"
                                Background="White"
                                BorderBrush="{StaticResource ModernBorderBrush}"
                                BorderThickness="1.2"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <Path x:Name="Ck"
                                  Data="M 2,7 L 6,11 L 13,3"
                                  Stroke="White" StrokeThickness="2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bx" Property="BorderBrush" Value="{StaticResource ModernAccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bx" Property="Background" Value="{StaticResource ModernAccentBrush}"/>
                            <Setter TargetName="Bx" Property="BorderBrush" Value="{StaticResource ModernAccentBrush}"/>
                            <Setter TargetName="Ck" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== RadioButton ===== -->
    <Style TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                            <Ellipse x:Name="OuterRing"
                                     Fill="White"
                                     Stroke="{StaticResource ModernBorderBrush}" StrokeThickness="1.2"/>
                            <Ellipse x:Name="Dot"
                                     Width="7" Height="7"
                                     Fill="{StaticResource ModernAccentBrush}"
                                     Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter Margin="6,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterRing" Property="Stroke" Value="{StaticResource ModernAccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="OuterRing" Property="Stroke" Value="{StaticResource ModernAccentBrush}"/>
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== GroupBox ===== -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="Margin"  Value="2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="Body"
                                Grid.Row="1"
                                CornerRadius="{StaticResource ModernCornerRadius}"
                                Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <Border Grid.Row="0"
                                Background="White"
                                Margin="12,0,0,-1"
                                Padding="4,0"
                                HorizontalAlignment="Left">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.FontWeight="SemiBold"
                                              TextElement.Foreground="{StaticResource ModernTextBrush}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== TabControl / TabItem ===== -->
    <Style TargetType="TabControl">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderBrush"     Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding"         Value="0"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource ModernMutedTextBrush}"/>
        <Setter Property="Padding"    Value="14,6"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter x:Name="Content"
                                          ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernAccentBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource ModernAccentBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Menu / MenuItem (top bar) ===== -->
    <Style TargetType="Menu">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
    </Style>

    <!-- Top-level menu items on the menu bar. Submenu items keep default look. -->
    <Style TargetType="MenuItem" x:Key="TopLevelMenuItem">
        <Setter Property="FontFamily" Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="Padding"    Value="14,6"/>
        <Setter Property="Margin"     Value="2,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   Focusable="False">
                                <Border Background="White"
                                        BorderBrush="{StaticResource ModernBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Margin="0,4,0,0"
                                        Padding="4">
                                    <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernAccentSoftBrush}"/>
                            <!-- Do not set Foreground here: it inherits into the popup items and makes
                                 the whole submenu text accent-blue. -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Speed toggle (active state = accent soft fill + accent border) ===== -->
    <Style x:Key="SpeedToggle" TargetType="ToggleButton">
        <Setter Property="Background"     Value="Transparent"/>
        <Setter Property="BorderBrush"    Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"        Value="3"/>
        <Setter Property="Cursor"         Value="Hand"/>
        <Setter Property="Width"          Value="28"/>
        <Setter Property="Height"         Value="24"/>
        <Setter Property="Margin"         Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernAccentSoftBrush}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ModernAccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== DataGrid ===== -->
    <Style TargetType="DataGrid">
        <Setter Property="FontFamily"          Value="{StaticResource ModernFontFamily}"/>
        <Setter Property="FontSize"            Value="{StaticResource ModernFontSize}"/>
        <Setter Property="Foreground"          Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="Background"          Value="White"/>
        <Setter Property="BorderBrush"         Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="RowHeight"           Value="28"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush"   Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource ModernAltRowBrush}"/>
        <Setter Property="RowBackground"            Value="White"/>
        <Setter Property="HeadersVisibility"        Value="Column"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="FontWeight"         Value="SemiBold"/>
        <Setter Property="Background"         Value="#F3F5F8"/>
        <Setter Property="Foreground"         Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="BorderBrush"        Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness"    Value="0,0,1,1"/>
        <Setter Property="Padding"            Value="10,6"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ModernHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource ModernAccentSoftBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--
        DataGridCell must own both Background and Foreground explicitly.
        WPF's default DataGridCell style has a trigger that sets Foreground
        to SystemColors.HighlightTextBrush (usually white) when IsSelected,
        which produced white-on-white when combined with our soft accent
        row background. Override the triggers explicitly to keep text dark.
    -->
    <Style TargetType="DataGridCell">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="10,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border x:Name="Bd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource ModernAccentBrush}"/>
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush"     Value="{StaticResource ModernAccentBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,0"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== ListBox / ListBoxItem ===== -->
    <Style TargetType="ListBox">
        <Setter Property="Background"      Value="White"/>
        <Setter Property="BorderBrush"     Value="{StaticResource ModernBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="2"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Foreground" Value="{StaticResource ModernTextBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ModernAccentSoftBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource ModernAccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ScrollBar (thin) ===== -->
    <Style TargetType="Thumb" x:Key="ModernScrollThumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="#C2CAD4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Margin="2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#9AA6B4"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="10"/>
        <Setter Property="MinWidth"   Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track Name="PART_Track" IsDirectionReversed="true">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ModernScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand"   Opacity="0" Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width"  Value="Auto"/>
                <Setter Property="Height" Value="10"/>
                <Setter Property="MinHeight" Value="10"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
