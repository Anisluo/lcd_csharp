<Window x:Class="LCD.View.MoveStyle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        mc:Ignorable="d"
        Title="MoveStyle" Height="650" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="120"/>
            <RowDefinition  Height="120"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>

        <WrapPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
            <Image Source="../Image/head.png"></Image>
            <Label Content="相机设置" VerticalAlignment="Center" FontSize="20"></Label>
        </WrapPanel>


        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Gray" BorderThickness="2" 
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="二轴"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="1"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0">
                    </Image>
                    <RadioButton Content="二轴(插补)"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>



            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="2"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="三轴"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>



            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="3"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="三轴(插补)"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>


            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="4"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="四轴"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>





            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="5"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" >
                    </Image>
                    <RadioButton Content="四轴(插补)"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>


        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Gray" BorderThickness="2" 
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="五轴(圆盘)"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="1"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="五轴(插补)"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>



            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="2"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="五轴"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>



            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="3"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="二轴"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>


            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="4"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="二轴"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>





            <Border BorderBrush="Gray" BorderThickness="2" 
            Grid.Column="5"
            CornerRadius="8"
                    Height="120" Width="85">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="85" Grid.Column="0" Grid.Row="0" >
                    </Image>
                    <RadioButton Content="二轴"
                    FontWeight="Bold"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
