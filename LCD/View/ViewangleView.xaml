<Window x:Class="LCD.View.ViewangleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        xmlns:app1="clr-namespace:LCD"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="{Binding [AngleSw], Source={x:Static app1:LanguageManager.Instance}}" Height="450" Width="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>

        <WrapPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
            <Image Source="../Image/head.png"></Image>
            <Label Content="{Binding [Sr3aAngle], Source={x:Static app1:LanguageManager.Instance}}" VerticalAlignment="Center" FontSize="20"></Label>
        </WrapPanel>


        <Grid Grid.Row="2" Name="Offs">
            <WrapPanel FlowDirection="RightToLeft" 
            HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Button Content="FDL 2" Name="fdl2"
                Click="OnFdl2"
                FontWeight="Bold"
                FontSize="16"
                Background="White"
                        Width="120" Height="30"></Button>
            </WrapPanel>
        </Grid>
        <Grid Grid.Row="3" Name="XIANG">
            <WrapPanel FlowDirection="RightToLeft" 
            HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Button Content="FDL 1" Name="fdl1"
                Click="OnFdl1"
                FontWeight="Bold"
                FontSize="16"
                Background="White"
                        Width="120" Height="30"></Button>
            </WrapPanel>
        </Grid>

        <Grid Grid.Row="4">
            <WrapPanel FlowDirection="RightToLeft" 
            HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Button Content="FDL 0.2" Name="fdl02"
                Click="OnFdl02"
                FontWeight="Bold"
                FontSize="16"
                Background="White"
                        Width="120" Height="30"></Button>
            </WrapPanel>
        </Grid>
        <Grid Grid.Row="5">
            <WrapPanel FlowDirection="RightToLeft" 
            HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Button Content="FDL 0.1" Name="fdl01"
                Click="OnFdl01"
                FontWeight="Bold"
                FontSize="16"
                Background="White"
                        Width="120" Height="30"></Button>
            </WrapPanel>
        </Grid>
        
        <Grid Grid.Row="6">
            <WrapPanel FlowDirection="RightToLeft" 
            HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Button Content="{Binding [Close], Source={x:Static app1:LanguageManager.Instance}}"
                Click="OnClose"
                FontWeight="Bold"
                FontSize="16"
                Background="White"
                        Width="120" Height="30"></Button>
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
