<UserControl x:Class="LCD.View.PGDebug"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        xmlns:app1="clr-namespace:LCD"
        mc:Ignorable="d"
             d:DesignWidth="568"
             d:DesignHeight="390">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <TextBlock Text="{Binding [PgSettings], Source={x:Static app1:LanguageManager.Instance}}"
                           HorizontalAlignment="Center"
                           FontSize="20" />
            </Grid>
            <Grid Grid.Row="1">
                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0">
                    <TextBlock Text="{Binding [PicSwitch], Source={x:Static app1:LanguageManager.Instance}}" />
                    <TextBox Width="50"
                             Name="ImageSwitching"
                             Text="{Binding ImageSwitching}"></TextBox>
                </WrapPanel>
            </Grid>
            <Grid Grid.Row="2">
                <Border BorderThickness="0,0,0,1"
                        BorderBrush="Black">
                    <Button Content="{Binding [PicSw], Source={x:Static app1:LanguageManager.Instance}}" Background="White" Margin="5" Click="Button_Click"></Button>
                </Border>
            </Grid>
            <Grid Grid.Row="3">
                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0">
                    <TextBlock Text="{Binding [RgbSw], Source={x:Static app1:LanguageManager.Instance}}" />
                </WrapPanel>
            </Grid>
            <Grid Grid.Row="4">
                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="70,0,0,0">
                    <TextBlock Text="R：" />
                    <TextBox Width="50" Name="R"
                             Text="{Binding ImageSwitching}"></TextBox>
                </WrapPanel>
            </Grid>
            <Grid Grid.Row="5">
                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="70,0,0,0">
                    <TextBlock Text="G：" />
                    <TextBox Width="50"
                             Name="G"
                             Text="{Binding ImageSwitching}"></TextBox>
                </WrapPanel>
            </Grid>
            <Grid Grid.Row="6">
                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="70,0,0,0">
                    <TextBlock Text="B：" />
                    <TextBox Width="50"
                             Name="B"
                             Text="{Binding ImageSwitching}"></TextBox>
                </WrapPanel>
            </Grid>
            <Grid Grid.Row="7">
                <Border BorderThickness="0,0,0,1"
                        BorderBrush="Black">
                    <Button Content="{Binding [RgbSw2], Source={x:Static app1:LanguageManager.Instance}}" Margin="5"
                            Background="White" Click="Button_Click_1"></Button>
                </Border>
            </Grid>
        </Grid>
        <Grid Grid.Column="1">
            <ListBox Name="mylist1">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <WrapPanel Margin="4">
                            <TextBlock Width="20"
                                       Text="{Binding Name2}">
                            </TextBlock>
                            <TextBlock Width="180"
                                       Text="{Binding Name1}">
                            </TextBlock>
                        </WrapPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
       
    </Grid>
</UserControl>
