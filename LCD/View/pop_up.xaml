<Window x:Class="LCD.View.pop_up"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        xmlns:app1="clr-namespace:LCD"
        mc:Ignorable="d"
        Title="" Height="200" Width="450">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <WrapPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
                <Image Source="../Image/head.png"></Image>
                <Label Content=""  FontSize="20" Margin="0,0,70,0" VerticalAlignment="Center"></Label>
            </WrapPanel>
        </Grid>
        <Grid Grid.Row="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Name="Titel"  FontSize="25" ></TextBlock>
            <TextBox Name="lblName" Margin="0,10" Width="400" TextAlignment="Center" FontWeight="Bold">[No name entered]</TextBox>
            
        </StackPanel>
        </Grid>
        <Grid Grid.Row="2">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Stretch">
                <Button Name="Button1" Click="Button1_Click" Margin="0,10,100,0" Content="{Binding [OK], Source={x:Static app1:LanguageManager.Instance}}"></Button>
                <Button Name="Button2" Click="Button2_Click" Margin="0,10,0,0" Content="{Binding [Cancel], Source={x:Static app1:LanguageManager.Instance}}"></Button>
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
