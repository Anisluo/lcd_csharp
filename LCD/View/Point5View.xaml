<Window x:Class="LCD.View.Point5View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="Point5View" Height="650" Width="780">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <WrapPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
            <Image Source="../Image/head.png"></Image>
            <Label Content="5点标准模板" VerticalAlignment="Center" FontSize="20"></Label>
        </WrapPanel>
        <!--//设置标注点阵模板-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <Label Content="模板名称" Width="90"></Label>
                    <TextBox Width="120" Text="{Binding tempName}"></TextBox>
                </WrapPanel>

                <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                    <Label Content="屏幕长度" Width="90"></Label>
                    <TextBox Width="120" Text="{Binding productLength}"></TextBox>
                    <Label Content="毫米"></Label>
                </WrapPanel>
                <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                    <Label Content="屏幕宽度" Width="90"></Label>
                    <TextBox Width="120" Text="{Binding productWidth}"></TextBox>
                    <Label Content="毫米"></Label>
                </WrapPanel>

                <WrapPanel Grid.Row="3" VerticalAlignment="Center">
                    <Label Content="定位方式" Width="90"></Label>
                    <RadioButton Content="毫米定位" Width="80" VerticalAlignment="Center"></RadioButton>
                    <RadioButton Content="百分比定位" 
                                 Width="80" Margin="50,0,0,0" VerticalAlignment="Center"></RadioButton>
                </WrapPanel>


                <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                    <Label Content="定位参数" Width="90"></Label>
                    <Label Content="A =" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" 
                    Text="{Binding Ameter}"
                              VerticalAlignment="Center"></TextBox>
                    <Label Content="毫米" Width="40" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" 
                    Text="{Binding Apercent}"
                              VerticalAlignment="Center"></TextBox>
                    <Label Content="%" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>

                <WrapPanel Grid.Row="5" VerticalAlignment="Center">
                    <Label Content="B =" Margin="90,0,0,0" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" 
                    Text="{Binding Bmeter}"
                              VerticalAlignment="Center"></TextBox>
                    <Label Content="毫米" Width="40" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" 
                    Text="{Binding Bpercent}"
                              VerticalAlignment="Center"></TextBox>
                    <Label Content="%" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>


                <!--<WrapPanel Grid.Row="6" VerticalAlignment="Center">
                    <Label Content="行 =" Margin="90,0,0,0" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" VerticalAlignment="Center"></TextBox>
                </WrapPanel>
                <WrapPanel Grid.Row="7" VerticalAlignment="Center">
                    <Label Content="列 =" Margin="90,0,0,0" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" VerticalAlignment="Center"></TextBox>
                </WrapPanel>-->

                <Border Grid.Row="8" Grid.RowSpan="2" BorderThickness="2" BorderBrush="Gray" CornerRadius="8">
                    <Grid Grid.Row="8" Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="200" Height="200" Background="LightGray"></Canvas>
                    </Grid>
                </Border>
            </Grid>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid>
                    <Image Source="../Image/5Points.jpg"></Image>
                </Grid>

                <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                    <Label Content="测量点信息" Width="90"></Label>
                    <Label Content="序号" Width="50" VerticalAlignment="Center"></Label>
                    <TextBox x:Name="SerNo" Width="60" Text="{Binding SerNo}" VerticalAlignment="Center"></TextBox>
                    <Button Name="Buttonsave" Width="60"  Click="Buttonsave_Click" VerticalAlignment="Center"  >保存序号</Button>
                </WrapPanel>

                <WrapPanel Grid.Row="3" VerticalAlignment="Center">
                    <Label Content="X =" Margin="90,0,0,0" Width="50" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" Text="{Binding Xmeter}" VerticalAlignment="Center"></TextBox>
                    <Label Content="毫米" Width="40" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" Text="{Binding Xpercent}" VerticalAlignment="Center"></TextBox>
                    <Label Content="%" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>

                <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                    <Label Content="Y =" Margin="90,0,0,0" Width="50" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" Text="{Binding Ymeter}" VerticalAlignment="Center"></TextBox>
                    <Label Content="毫米" Width="40" VerticalAlignment="Center"></Label>
                    <TextBox  Width="60" Text="{Binding Ypercent}" VerticalAlignment="Center"></TextBox>
                    <Label Content="%" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>


                <WrapPanel Grid.Row="5" VerticalAlignment="Center">

                    <Label Content="测量标准：" Width="90"></Label>
                    <RadioButton Content="L:" VerticalAlignment="Center" Width="50"></RadioButton>
                    <TextBox Width="60" Text="{Binding Lmeter}" VerticalAlignment="Center" FontSize="14"></TextBox>
                    <Label Content="&lt;" Width="20" VerticalAlignment="Center" />
                    <Label Content="L"></Label>
                    <Label Content="&lt;" Width="20" />
                    <TextBox Width="60" Text="{Binding Lpercent}" VerticalAlignment="Center" FontSize="14"></TextBox>
                </WrapPanel>


                <WrapPanel Grid.Row="6" VerticalAlignment="Center">
                    <RadioButton Content="x:" VerticalAlignment="Center" 
                    Margin="90,0,0,0"
                                 Width="50"></RadioButton>
                    <TextBox Width="60" Text="{Binding Xmeter}" VerticalAlignment="Center" FontSize="14"></TextBox>
                    <Label Content="&lt;" Width="20" VerticalAlignment="Center" />
                    <Label Content="x"></Label>
                    <Label Content="&lt;"  Width="20" />
                    <TextBox Width="60" Text="{Binding Xpercent}" VerticalAlignment="Center" FontSize="14"></TextBox>
                </WrapPanel>



                <WrapPanel Grid.Row="7" VerticalAlignment="Center">
                    <RadioButton Content="y:"
                    Margin="90,0,0,0"
                                 VerticalAlignment="Center" Width="50"></RadioButton>
                    <TextBox Width="60" Text="{Binding Ymeter}" VerticalAlignment="Center" FontSize="14"></TextBox>
                    <Label Content="&lt;" Width="20" VerticalAlignment="Center" />
                    <Label Content="y"></Label>
                    <Label Content="&lt;" Width="20" />
                    <TextBox Width="60" Text="{Binding Ypercent}" VerticalAlignment="Center" FontSize="14"></TextBox>
                </WrapPanel>


            </Grid>


        </Grid>
        <Grid Grid.Row="2" Background="White">
            <WrapPanel VerticalAlignment="Center" 
            HorizontalAlignment="Center"
                       FlowDirection="RightToLeft">

                <Button Content="确定"
                Opacity="1"
                FontWeight="Bold"
                Width="120"
                Click="OnBnClickedEnsure"
                Height="30"
                FontSize="16"
                        Margin="0,0,90,0"></Button>
                <Button Content="另存为文件" 
                Opacity="1"
                Width="120"
                Height="30"
                Click="OnBnClickedSave"
                FontWeight="Bold"
                FontSize="16"
                        ></Button>
            </WrapPanel>
        </Grid>



    </Grid>
</Window>
