<Window x:Class="LCD.View.DevicesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        xmlns:app1="clr-namespace:LCD"
        ResizeMode="NoResize"
        mc:Ignorable="d"
        Title="{Binding [InstSet], Source={x:Static app1:LanguageManager.Instance}}" Height="750" Width="780" DataContext="{Binding Mode=OneWay, RelativeSource={RelativeSource Self}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="350"/>
            <RowDefinition Height="40"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>

        <WrapPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
            <Image Source="../Image/head.png"></Image>
            <Label Content="{Binding [InstrSet], Source={x:Static app1:LanguageManager.Instance}}" VerticalAlignment="Center" FontSize="20"></Label>
        </WrapPanel>


        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Gray" BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image  Height="130" Grid.Column="0" Grid.Row="0" Source="../Image/BM7.png">
                    </Image>
                    <RadioButton Content="BM7-A"
                    FontWeight="Bold"
                    Name="BM7A"
                    Click="OnBnClickedBM7A"
                                 Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>


            <Border BorderBrush="Gray" 
                Grid.Column="1" Grid.Row="0"
                        BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0"
                    Height="130"
                           Grid.Row="0" Source="../Image/BM5A.png">
                    </Image>
                    <RadioButton Content="BM-5A"
                    FontWeight="Bold"
                    x:Name="BM5A"
                    Click="OnBnClickedBM5A"
                                 Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>



            <Border BorderBrush="Gray" 
                Grid.Column="2" Grid.Row="0"
                        BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0"
                    Height="130"
                           Grid.Row="0" Source="../Image/PR655.png">
                    </Image>
                    <RadioButton Content="PR655/670"
                    FontWeight="Bold"
                    Click="OnBnClickedPR655"
                    x:Name="PR655"
                                 Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>



            <Border BorderBrush="Gray" 
                Grid.Column="3" Grid.Row="0"
                        BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0" 
                    Height="130"
                           Grid.Row="0" Source="../Image/CS2000.png">
                    </Image>
                    <RadioButton Content="CS-2000/3000"
                    FontWeight="Bold"
                    x:Name="CS2000"
                              Click="OnBnClickedCS2000"
                                 Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" 
                Grid.Column="4" Grid.Row="0"
                        BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0" 
                    Height="130"
                           Grid.Row="0" Source="../Image/CS2000.png">
                    </Image>
                    <RadioButton Content="Admesy"
                    FontWeight="Bold"
                    x:Name="Admesy"
                              Click="OnBnClickedAdmesy"
                                 Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" 
                Grid.Column="5" Grid.Row="0"
                BorderThickness="2" 
                CornerRadius="8"
                Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0" 
                    Height="130"
                    Grid.Row="0" Source="../Image/CS2000.png">
                    </Image>
                    <RadioButton Content="MS01"
                    FontWeight="Bold"
                    x:Name="MS01"
                    Click="OnBnClickedMs01"
                     Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" 
                Grid.Column="0" Grid.Row="1"
                        BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0"
                    Height="130"
                           Grid.Row="0" Source="../Image/SR3A.png">
                    </Image>
                    <RadioButton Content="SR-3A"
                    FontWeight="Bold"
                              x:Name="SR3A"
                    Click="OnBnClickedSR3A"
                                 Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" 
                Grid.Column="1" Grid.Row="1"
                BorderThickness="2" 
                CornerRadius="8"
                Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0"
                    Height="130"
                    Grid.Row="0" Source="../Image/SR3A.png">
                    </Image>
                    <RadioButton Content="SR-5/5A"
                        FontWeight="Bold"
                        x:Name="SR5A"
                        Click="OnBnClickedSR5A"
                     Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>



            <Border BorderBrush="Gray" 
                Grid.Column="2" Grid.Row="1"
                        BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0" 
                    Height="130"
                           Grid.Row="0" Source="../Image/BM5AS.png">
                    </Image>
                    <RadioButton Content="BM-5AS"
                    FontWeight="Bold"
                    x:Name="BM5AS"
                              Click="OnBnClickedBM5AS"
                                 Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>



            <Border BorderBrush="Gray" 
                Grid.Column="3" Grid.Row="1"
                        BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0"
                    Height="130"
                           Grid.Row="0" Source="../Image/CS200.png">
                    </Image>
                    <RadioButton Content="USB-2000"
                    FontWeight="Bold"
                              x:Name="CS200"
                              Click="OnBnClickedCS200"
                                 Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Border BorderBrush="Gray" 
                Grid.Column="4" Grid.Row="1"
                        BorderThickness="2" 
            CornerRadius="8"
                    Height="170" Width="130">
                <StackPanel HorizontalAlignment="Center">
                    <Image Grid.Column="0" 
                    Height="130"
                           Grid.Row="0" 
                           Source="../Image/Demo.png">
                    </Image>
                    <RadioButton Content="{Binding [DemoMode], Source={x:Static app1:LanguageManager.Instance}}"
                    FontWeight="Bold"
                                 Name="demo"
                                 Click="OnBnClickedDemo"
                                 Margin="0,10,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" >
            <WrapPanel VerticalAlignment="Center">
                <Label Content="{Binding [CorrectFactor], Source={x:Static app1:LanguageManager.Instance}}" Width="90" Margin="20,0,0,0" FontSize="14"></Label>
                <Label Content="{Binding [Brightness], Source={x:Static app1:LanguageManager.Instance}}" Width="50" FontSize="14"></Label>
                <TextBox Width="80" 
                Text="{Binding lum}"
                         FontSize="14" VerticalAlignment="Center"></TextBox>

                <Label Content="{Binding [ColorX], Source={x:Static app1:LanguageManager.Instance}}" Width="70" FontSize="14"></Label>
                <TextBox Width="80" 
                Text="{Binding cx}"
                         VerticalAlignment="Center" FontSize="14"></TextBox>


                <Label Content="{Binding [ColorY], Source={x:Static app1:LanguageManager.Instance}}" Width="70" FontSize="14"></Label>
                <TextBox Width="80" 
                Text="{Binding cy}"
                         FontSize="14" VerticalAlignment="Center"></TextBox>
            </WrapPanel>
        </Grid>


        <Grid Grid.Row="3" Name="General" Visibility="Hidden" >
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <WrapPanel  VerticalAlignment="Center">
                <Label Content="{Binding [TestSetDash], Source={x:Static app1:LanguageManager.Instance}}" Width="90"  FontSize="14"></Label>
                <Label Content="{Binding [StartDelay], Source={x:Static app1:LanguageManager.Instance}}" Width="80" FontSize="14"></Label>
                <TextBox Width="80" FontSize="14" Text="{Binding startDelay}" VerticalAlignment="Center"></TextBox>
                <Label Content="{Binding [MS], Source={x:Static app1:LanguageManager.Instance}}" Width="80" FontSize="14"></Label>
                <Label Content="{Binding [HotDelay], Source={x:Static app1:LanguageManager.Instance}}"></Label>
            </WrapPanel>

            <WrapPanel Grid.Row="1"  VerticalAlignment="Center">
                <Label Content="{Binding [TimeOutDash], Source={x:Static app1:LanguageManager.Instance}}" Margin="90,0,0,0" Width="80" FontSize="14"></Label>
                <TextBox Width="80" FontSize="14" Text="{Binding mesDelay}" VerticalAlignment="Center"></TextBox>
                <Label Content="{Binding [MS], Source={x:Static app1:LanguageManager.Instance}}" Width="80" FontSize="14"></Label>
                <Label Content="{Binding [InstrTestTimeout], Source={x:Static app1:LanguageManager.Instance}}"></Label>
            </WrapPanel>


            <WrapPanel Grid.Row="2"  VerticalAlignment="Center">
                <Label Content="{Binding [RestartTime], Source={x:Static app1:LanguageManager.Instance}}" Margin="90,0,0,0" Width="80" FontSize="14"></Label>
                <TextBox Width="80" FontSize="14" VerticalAlignment="Center" Text="{Binding resetDelay}"></TextBox>
                <Label Content="{Binding [MS], Source={x:Static app1:LanguageManager.Instance}}" Width="80" FontSize="14"></Label>
                <Label Content="{Binding [InstrRestartTime], Source={x:Static app1:LanguageManager.Instance}}"></Label>
            </WrapPanel>

            <!--<WrapPanel Grid.Row="3"  VerticalAlignment="Center">
                <Label Content="测量延时：" Margin="90,0,0,0" Width="80" FontSize="14"></Label>
                <TextBox Width="80" FontSize="14" VerticalAlignment="Center"></TextBox>
                <Label Content="毫秒(ms)" Width="80" FontSize="14"></Label>
                <Label Content="程序启动后第一次测量等待时间"></Label>
            </WrapPanel>-->
        </Grid>




        <Grid Grid.Row="3" Name="USB2000" Visibility="Visible"  >
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <WrapPanel  VerticalAlignment="Center">
                <Label Content="{Binding [ParaSetDash], Source={x:Static app1:LanguageManager.Instance}}" Width="90"  FontSize="14"></Label>
                <Label Content="{Binding [IntegrationTime], Source={x:Static app1:LanguageManager.Instance}}" Width="80" FontSize="14"></Label>
                <TextBox Width="80" FontSize="14" Text="{Binding startDelay}" VerticalAlignment="Center"></TextBox>
                <Label Content="{Binding [MS], Source={x:Static app1:LanguageManager.Instance}}" Width="80" FontSize="14"></Label>
                <Label Content="{Binding [U2000IntTime], Source={x:Static app1:LanguageManager.Instance}}"></Label>
            </WrapPanel>
        </Grid>




        <Grid Grid.Row="4" Name="General_Com" Visibility="Visible" >
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <WrapPanel  VerticalAlignment="Center" >
                <Label Content="{Binding [CommSetDash], Source={x:Static app1:LanguageManager.Instance}}" Width="90"  FontSize="14"></Label>
                <Label Content="{Binding [CommPortDash], Source={x:Static app1:LanguageManager.Instance}}" Width="80" FontSize="14"></Label>
                <ComboBox Width="80" FontSize="14" 
                Name="myports"
                          VerticalAlignment="Center"
                          Text="{Binding comName,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"></ComboBox>

                <Label Content="{Binding [BaudDash], Source={x:Static app1:LanguageManager.Instance}}" Margin="20,0,0,0" Width="80" FontSize="14"></Label>
                <ComboBox Width="80"
                          x:Name="_bardRate"
                          SelectedIndex="{Binding bardRate,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         
                          FontSize="14" VerticalAlignment="Center">
                    <ComboBoxItem>9600</ComboBoxItem>
                    <ComboBoxItem>38400</ComboBoxItem>
                    <ComboBoxItem>115200</ComboBoxItem>
                </ComboBox>
            </WrapPanel>

            <WrapPanel  Grid.Row="1" VerticalAlignment="Center">
                <Label Content="{Binding [DataWidDash], Source={x:Static app1:LanguageManager.Instance}}" Margin="90,0,0,0" Width="80" FontSize="14"></Label>
                <ComboBox Width="80"
                          x:Name="_dataBit"
                          SelectedIndex="{Binding dataBit,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        
                          FontSize="14" VerticalAlignment="Center">
                    <ComboBoxItem>6</ComboBoxItem>
                    <ComboBoxItem>7</ComboBoxItem>
                    <ComboBoxItem>8</ComboBoxItem>

                </ComboBox>

                <Label Content="{Binding [StopBitsDash], Source={x:Static app1:LanguageManager.Instance}}" Margin="20,0,0,0" Width="80" FontSize="14"></Label>
                <ComboBox Width="80"
                          x:Name="_stopBit"
                          SelectedIndex="{Binding stopBit,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         
                          FontSize="14" VerticalAlignment="Center">
                    <ComboBoxItem>0</ComboBoxItem>
                    <ComboBoxItem>1</ComboBoxItem>
                </ComboBox>
                <!--Name="Parity"-->
                <Label Content="{Binding [ParityDash], Source={x:Static app1:LanguageManager.Instance}}" Margin="20,0,0,0" Width="80" FontSize="14"></Label>
                <ComboBox Width="80"
                          x:Name="_Parity"
                          SelectedIndex="{Binding Parity,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          
                          FontSize="14" VerticalAlignment="Center">
                    <ComboBoxItem>None</ComboBoxItem>
                    <ComboBoxItem>Odd</ComboBoxItem>
                    <ComboBoxItem>Even</ComboBoxItem>
                </ComboBox>
            </WrapPanel>

        </Grid>
        
        <Grid Grid.Row="5">
            <WrapPanel FlowDirection="RightToLeft" 
            HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Button Content="{Binding [OK], Source={x:Static app1:LanguageManager.Instance}}"
                Click="OnBnClickedEnsure"
                        Width="120" Height="30"></Button>
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
