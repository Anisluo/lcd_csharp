<Window x:Class="LCD.View.MoveDebugView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        xmlns:app1="clr-namespace:LCD"
        mc:Ignorable="d"
        Title="运动轴调试" Height="350" Width="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5*">
            </RowDefinition>
            <RowDefinition>
            </RowDefinition>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                    <Label Content="{Binding [InputCoord], Source={x:Static app1:LanguageManager.Instance}}" Width="90" Margin="20,0,0,0"></Label>
                </WrapPanel>
                
                <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                    <Label Content="{Binding [XAxis], Source={x:Static app1:LanguageManager.Instance}}" Margin="90,0,0,0" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox x:Name="xval" Width="60" 
                    Text=""
                    VerticalAlignment="Center"></TextBox>
                    <Label Content="{Binding [MM], Source={x:Static app1:LanguageManager.Instance}}" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>

                <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                    <Label Content="{Binding [YAxis], Source={x:Static app1:LanguageManager.Instance}}" Margin="90,0,0,0" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox x:Name="yval" Width="60" 
                    Text=""
                    VerticalAlignment="Center"></TextBox>
                    <Label Content="{Binding [MM], Source={x:Static app1:LanguageManager.Instance}}" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>

                <WrapPanel Grid.Row="3" VerticalAlignment="Center">
                    <Label Content="{Binding [ZAxis], Source={x:Static app1:LanguageManager.Instance}}" Margin="90,0,0,0" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox x:Name="zval" Width="60" 
                    Text=""
                    VerticalAlignment="Center"></TextBox>
                    <Label Content="{Binding [MM], Source={x:Static app1:LanguageManager.Instance}}" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>

                <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                    <Label Content="{Binding [UAxis], Source={x:Static app1:LanguageManager.Instance}}" Margin="90,0,0,0" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox x:Name="uval" Width="60" 
                    Text=""
                    VerticalAlignment="Center"></TextBox>
                    <Label Content="{Binding [Degree], Source={x:Static app1:LanguageManager.Instance}}" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>

                <WrapPanel Grid.Row="5" VerticalAlignment="Center">
                    <Label Content="{Binding [VAxis], Source={x:Static app1:LanguageManager.Instance}}" Margin="90,0,0,0" Width="30" VerticalAlignment="Center"></Label>
                    <TextBox x:Name="vval" Width="60" 
                    Text=""
                    VerticalAlignment="Center"></TextBox>
                    <Label Content="{Binding [Degree], Source={x:Static app1:LanguageManager.Instance}}" Width="40" VerticalAlignment="Center"></Label>
                </WrapPanel>

            </Grid>
        </Grid>

        <Grid Grid.Row="1" Background="White">
            <WrapPanel VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                FlowDirection="RightToLeft">

                <Button Content="{Binding [Cancel], Source={x:Static app1:LanguageManager.Instance}}" 
                  Width="50"
                  Height="30"
                  Opacity="1"
                  FontWeight="Bold"
                  Margin="0,0,40,0"
                  FontSize="16" Click="Button_Cancel_Click" >
                </Button>

                <Button Content="{Binding [MovePosition], Source={x:Static app1:LanguageManager.Instance}}" 
                     Width="150"
                     Height="30"
                     Opacity="1"
                     FontWeight="Bold"
                     FontSize="16" Click="Button_Click" >
                </Button>

                
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
