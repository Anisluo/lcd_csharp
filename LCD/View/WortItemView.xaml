<UserControl x:Class="LCD.View.WortItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LCD.View"
             xmlns:my="clr-namespace:System.Windows.Controls;assembly=StiZoomableCanvas"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Name="myCanvas" Margin="0,40,0,0"  >
            <Canvas Background="Transparent" 
MouseMove="myinnerCanvas_MouseMove"
                        MouseWheel="OnMouseWheel"
  MouseLeftButtonDown="myinnerCanvas_MouseLeftButtonDown"
            MouseLeftButtonUp="myinnerCanvas_MouseLeftButtonUp"
                  Name="myinnerCanvas"  ></Canvas>
    </Grid>
</UserControl>
