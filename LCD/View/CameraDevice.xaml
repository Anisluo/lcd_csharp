        <Grid Grid.Row="2" Name="Offs">
            <WrapPanel x:Name="Offset" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Content="{Binding [Xpercent], Source={x:Static app1:LanguageManager.Instance}}" Margin="20,0,0,0" FontSize="14"></Label>
                <TextBox Width="80" Text="{Binding X,UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalAlignment="Center"></TextBox>
                <Label Content="{Binding [YPercent], Source={x:Static app1:LanguageManager.Instance}}" FontSize="14"></Label>
                <TextBox Width="80" Text="{Binding Y,UpdateSourceTrigger=PropertyChanged}" FontSize="14" VerticalAlignment="Center"></TextBox>

                <!--<TextBox Name="Cam" Width="80" FontSize="14" VerticalAlignment="Center">8000</TextBox>-->
                <!--<Label Content="ms" Width="50" FontSize="14"></Label>-->
            </WrapPanel>
        </Grid>
        <Grid Grid.Row="3" Name="XIANG">
            <WrapPanel x:Name="Offset2" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Label Content="{Binding [RotationAngle], Source={x:Static app1:LanguageManager.Instance}}" Width="80" Margin="0,0,0,0" FontSize="14"></Label>
                <ComboBox Name="Rotation"  Width="80" Margin="20,0,0,0" SelectedIndex="0" >
                    <ComboBoxItem>0</ComboBoxItem>
                    <ComboBoxItem>90</ComboBoxItem>
                    <ComboBoxItem>180</ComboBoxItem>
                    <ComboBoxItem>270</ComboBoxItem>
                </ComboBox>
                <Button Content="OK"
                    Click="OnRotation"
                    FontWeight="Bold"
                    FontSize="16"
                    Background="White"
                     Margin="20,0,0,0"
                Width="80" Height="30"></Button>
            </WrapPanel>
        </Grid>




        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <WrapPanel  VerticalAlignment="Center" Visibility="Hidden">
                <Label Content="通信设定：" Width="90"  Margin="20,0,0,0" FontSize="14"></Label>
                <Label Content="IP地址：" Width="80" FontSize="14"></Label>
                <TextBox Width="180" FontSize="14" VerticalAlignment="Center"></TextBox>

                <Label Content="端口：" Margin="20,0,0,0" Width="80" FontSize="14"></Label>
                <TextBox Width="80" FontSize="14" VerticalAlignment="Center"></TextBox>
            </WrapPanel>

            <!--<WrapPanel  Grid.Row="1" VerticalAlignment="Center">
