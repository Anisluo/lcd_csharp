<UserControl x:Class="LCD.View.WaveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LCD.View"
             mc:Ignorable="d" 
                              xmlns:ext="http://schemas.abtsoftware.co.uk/scichart/exampleExternals"
                      xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SciChart.Examples.ExternalDependencies;component/Resources/Styles/ToolbarButtonsCommon.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>


        <ext:SciChartInteractionToolbar 
 Grid.Row="0"
     TargetSurface="{Binding Source={x:Reference Name=sciChart}}">

            <ext:FlyoutSeparator Background="#444" />

            <ext:FlyoutMenuButton Content="滤波"
                                  Padding="0"
                                  Style="{StaticResource FlyoutMenuButtonStyle}">
                <ext:FlyoutMenuButton.PopupContent>
                    <StackPanel MinWidth="320" MinHeight="200" Orientation="Vertical">
                        <TextBlock Text="滤波设置" />
                        <ext:FlyoutSeparator />
                        <WrapPanel Margin="5" VerticalAlignment="Center">
                            <Label Content="滤波方式：" Width="80" FontWeight="Bold" FontSize="16" Foreground="White"></Label>
                            <ComboBox  Width="120" SelectedIndex="0" FontSize="16">
                                <ComboBoxItem>滑动窗口滤波</ComboBoxItem>
                                <ComboBoxItem>FaltTop滤波</ComboBoxItem>
                            </ComboBox>
                        </WrapPanel>
                        <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        </WrapPanel>


                    </StackPanel>
                </ext:FlyoutMenuButton.PopupContent>
            </ext:FlyoutMenuButton>

            <ext:FlyoutMenuButton Content="设置"
                                  Padding="0"
                                  Style="{StaticResource FlyoutMenuButtonStyle}" >
                <ext:FlyoutMenuButton.PopupContent>
                    <StackPanel MinWidth="320" MinHeight="200" Orientation="Vertical">
                        <TextBlock Text="参数设置" />
                        <ext:FlyoutSeparator />
                        <!--<WrapPanel Margin="5" VerticalAlignment="Center">
                            <Label Content="串口：" Width="80" FontWeight="Bold" FontSize="16" Foreground="White"></Label>
                            <ComboBox  Width="120" FontSize="16"></ComboBox>
                        </WrapPanel>-->

                        <!--Create the size slider-->
                        <WrapPanel Margin="5" VerticalAlignment="Center">
                            <Label Content="增益：" Width="80" FontWeight="Bold" FontSize="16" Foreground="White"></Label>
                            <TextBox  Width="120" Name="gain" FontSize="16"></TextBox>
                        </WrapPanel>

                        <WrapPanel Margin="5"  VerticalAlignment="Center">
                            <Label Content="采样频率：" Foreground="White" Width="80" FontSize="16" FontWeight="Bold"></Label>
                            <TextBox Width="120" Name="sampleRate" FontSize="16" ></TextBox>
                        </WrapPanel>


                        <WrapPanel Margin="5" VerticalAlignment="Center">
                            <Label Content="采样点数：" Foreground="White" Width="80" FontSize="16" FontWeight="Bold"></Label>
                            <TextBox Width="120" Name="sampleCount" FontSize="16"></TextBox>

                        </WrapPanel>


                        <WrapPanel Margin="5" HorizontalAlignment="Center">
                            <Button Width="110" HorizontalAlignment="Center"
                            Content="刷新参数"
                                    FontSize="16"></Button>

                        </WrapPanel>

                    </StackPanel>
                </ext:FlyoutMenuButton.PopupContent>
            </ext:FlyoutMenuButton>

        </ext:SciChartInteractionToolbar>



        <ext:SciChartInteractionToolbar 
        Grid.Row="1"
            TargetSurface="{Binding Source={x:Reference Name=sciChart2}}" />
        <!--</Grid>-->

        <Grid Grid.Column="1"  
        Panel.ZIndex="1"
              Margin="40,3,0,0" Height="120" Width="180" HorizontalAlignment="Left"
        Background="Transparent"
        VerticalAlignment="Top"
              >
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                <Label Content="上升时间：" Foreground="White"></Label>
                <TextBlock Text="0.000" Name="Rise" Foreground="White"></TextBlock>
            </WrapPanel>


            <WrapPanel Grid.Row="3" VerticalAlignment="Center">
                <Label Content="下降时间：" Foreground="White"></Label>
                <TextBlock Text="0.000" Name="Fall" Foreground="White"></TextBlock>
            </WrapPanel>





        </Grid>

        <Grid Grid.Column="1" Grid.RowSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <s:SciChartSurface x:Name="sciChart" Grid.Column="1" BorderThickness="0"
                           >
                <!--  Declare RenderableSeries  -->
                <s:SciChartSurface.RenderableSeries >
                    <s:FastLineRenderableSeries x:Name="lineRenderSeries"
                                            Stroke="#FF99EE99"
                                            StrokeThickness="2">
                        <s:FastLineRenderableSeries.SeriesAnimation>
                            <s:SweepAnimation AnimationDelay="0:0:1" Duration="0:0:1"/>
                        </s:FastLineRenderableSeries.SeriesAnimation>
                    </s:FastLineRenderableSeries>
                </s:SciChartSurface.RenderableSeries>

                <!--  Create an X Axis with Growby  -->
                <s:SciChartSurface.XAxis>
                    <s:NumericAxis DrawMajorBands="True"
                               GrowBy="0.1, 0.1"
                               TextFormatting="#.############" />
                </s:SciChartSurface.XAxis>

                <!--  Create a Y Axis with Growby. Optional bands give a cool look and feel for minimal performance impact  -->
                <s:SciChartSurface.YAxis>
                    <s:NumericAxis DrawMajorBands="True" GrowBy="0.5, 0.5" />
                </s:SciChartSurface.YAxis>

                <s:SciChartSurface.ChartModifier>
                    <s:ModifierGroup>
                        <s:RolloverModifier ShowTooltipOn="MouseHover" />
                        <s:LegendModifier ShowLegend="True"/>
                    </s:ModifierGroup>
                </s:SciChartSurface.ChartModifier>

            </s:SciChartSurface>




            <s:SciChartSurface x:Name="sciChart2" Grid.Column="1" Grid.Row="1" BorderThickness="0"
            
                               >
                <!--  Declare RenderableSeries  -->
                <s:SciChartSurface.RenderableSeries>
                    <s:FastLineRenderableSeries x:Name="lineRenderSeries2"
                                            Stroke="#FF99EE99"
                                            StrokeThickness="2">
                    </s:FastLineRenderableSeries>
                </s:SciChartSurface.RenderableSeries>

                <!--  Create an X Axis with Growby  -->
                <s:SciChartSurface.XAxis>
                    <s:NumericAxis DrawMajorBands="True"
                               GrowBy="0.1, 0.1"
                               TextFormatting="#.############" />
                </s:SciChartSurface.XAxis>

                <!--  Create a Y Axis with Growby. Optional bands give a cool look and feel for minimal performance impact  -->
                <s:SciChartSurface.YAxis >
                    <s:NumericAxis DrawMajorBands="True" GrowBy="0.5, 0.5" />
                </s:SciChartSurface.YAxis>

                <s:SciChartSurface.ChartModifier>
                    <s:ModifierGroup>
                        <s:RolloverModifier ShowTooltipOn="MouseHover" />
                        <s:LegendModifier ShowLegend="True"/>
                    </s:ModifierGroup>
                </s:SciChartSurface.ChartModifier>

            </s:SciChartSurface>

        </Grid>
    </Grid>
</UserControl>
