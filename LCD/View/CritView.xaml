<Window x:Class="LCD.View.CritView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        xmlns:app1="clr-namespace:LCD"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="CritView" Height="450" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <WrapPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
            <Image Source="../Image/head.png"></Image>
            <Label Content="{Binding [SetResultFormat], Source={x:Static app1:LanguageManager.Instance}}"  
                   FontSize="20" 
                   VerticalAlignment="Center"></Label>
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <WrapPanel VerticalAlignment="Center"
                           HorizontalAlignment="Center">

                    <Button Height="20" Content="{Binding [SelectAll], Source={x:Static app1:LanguageManager.Instance}}" 
                    Click="OnBnClickedSelectALL"
                            Background="White" Width="100"/>
                    <Button Height="20" 
                            Content="{Binding [SelectNone], Source={x:Static app1:LanguageManager.Instance}}"
                            Margin="40,0,0,0"
                            Click="OnBnClickedUnSelectALL"
                            Background="White" 
                            Width="100"/>
                </WrapPanel>
                <ListBox
                Name="mylist"
                    Grid.Row="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <WrapPanel>
                                <CheckBox 
                                    IsChecked="{Binding Path=IsCHK, BindsDirectlyToSource=True}" 
                                    Content="{Binding  Path=Name, BindsDirectlyToSource=True}" />
                            </WrapPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!--<ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="X(坐标：mm)"
                            IsChecked="{Binding IsXptCHK}"
                                      ></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>-->

                        <!--<ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="Y(坐标：mm)"
                                      ></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="Z(坐标：mm)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="U(水平旋转坐标：°)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="V(垂直旋转坐标：°)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="ball(积分球载臂坐标：mm)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="L(亮度)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="cx(色坐标)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="cy(色坐标)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="Tc(色温)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="u'"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="v'"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="X(三刺激值)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="Y(三刺激值)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="Z(三刺激值)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="Voltage(电压：V)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>
                    <ListBoxItem>
                        <WrapPanel>
                            <CheckBox Content="波长(光谱)"></CheckBox>
                        </WrapPanel>
                    </ListBoxItem>-->
                <!--</ListBox>-->
            </Grid>
            

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <!--<Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0">
                        <Label Content="判断标准与颜色"></Label>
                    </WrapPanel>

                 </Grid>-->



                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0">
                        <Label Content="{Binding [EqliCalc], Source={x:Static app1:LanguageManager.Instance}}"></Label>
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                        <RadioButton Content="Min/Max"
                        Click="OnBnClickedMimMax_1"
                                     Margin="60,0,0,0" VerticalAlignment="Center" Width="120"></RadioButton>
                    </WrapPanel>


                    <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                        <RadioButton Content="(Max-Min)/Max" 
                        Click="OnBnClickedMinMax_2"
                                     Margin="60,0,0,0" VerticalAlignment="Center" Width="120"></RadioButton>
                    </WrapPanel>


                    <WrapPanel Grid.Row="3" VerticalAlignment="Center">
                        <RadioButton Content="(Max-Min)/Avg"
                        Click="OnBnClickedMinMax_3"
                                     Margin="60,0,0,0" VerticalAlignment="Center" Width="120"></RadioButton>
                    </WrapPanel>
                </Grid>


            </Grid>
         
        </Grid>
   <WrapPanel Grid.Row="2" FlowDirection="RightToLeft"
   VerticalAlignment="Center" HorizontalAlignment="Center"
              >
                <Button Width="120" Height="30"
                Click="OnBnClickedEnsure"
                        Content="{Binding [OK], Source={x:Static app1:LanguageManager.Instance}}"></Button>
            </WrapPanel>
    </Grid>
</Window>
