<UserControl x:Class="LCD.View.DeviceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD"
        xmlns:app1="clr-namespace:LCD"
        mc:Ignorable="d"
             Background="White"
             Loaded="UserControl_Loaded"
         HorizontalAlignment="Stretch" DataContext="{Binding Mode=OneWay, RelativeSource={RelativeSource Self}}" 
         d:DesignWidth="568" d:DesignHeight="390">
    <UserControl.Resources>
    </UserControl.Resources>
    <Grid>
        <Grid Margin="0,3,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30*"/>
                <ColumnDefinition Width="60*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="220"/>
                <RowDefinition Height="50*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <!--设备列表-->
            <Grid Grid.Row="0" Grid.Column="0" Margin="0,10,0,10">
                <GroupBox Header="{Binding [CommDevList], Source={x:Static app1:LanguageManager.Instance}}">
                    <Grid>
                        <Grid.ColumnDefinitions></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="3"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30*"/>
                        </Grid.RowDefinitions>

                        <ComboBox Grid.Row="1" HorizontalAlignment="Stretch" Margin="10,0,70,0" Height="20" ItemsSource="{Binding Infos}" DisplayMemberPath="Name"/>

                        <Button Grid.Row="1" Content="{Binding [Add], Source={x:Static app1:LanguageManager.Instance}}" HorizontalAlignment="Right" Margin="0,0,10,0" Width="50" Height="20" Click="AddDevice_Click"/>

                        <Button Grid.Row="2" Content="{Binding [Delete], Source={x:Static app1:LanguageManager.Instance}}" Height="20" Margin="10,0"/>
                        <ListView x:Name="listView" Grid.Row="3" Margin="10,0" ItemsSource="{Binding Devices}" DisplayMemberPath="Key"/>
                    </Grid>
                </GroupBox>
            </Grid>
            <GroupBox Header="{Binding [Property], Source={x:Static app1:LanguageManager.Instance}}" Grid.Row="0" Grid.Column="1" Margin="0,10,0,10">
                <Grid DataContext="{Binding SelectedValue, ElementName=listView}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30*"/>
                        <ColumnDefinition Width="60*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                        <RowDefinition Height="27"/>
                    </Grid.RowDefinitions>
                    <Grid.Resources>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                        </Style>

                        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxBaseStyle}">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="MinHeight" Value="20"/>
                            <Setter Property="Padding" Value="0,0,0,0"/>
                        </Style>

                        <Style TargetType="CheckBox">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="10,0"/>
                        </Style>
                    </Grid.Resources>

                    <Button Grid.Row="0" Content="{Binding [EnableIt], Source={x:Static app1:LanguageManager.Instance}}" Click="Enable_Click"/>
                    <Button Grid.Row="1" Content="{Binding [PointCheck], Source={x:Static app1:LanguageManager.Instance}}" Click="ReadData_Click"/>
                    <TextBlock Grid.Row="2" Text="{Binding [NoteDash], Source={x:Static app1:LanguageManager.Instance}}"/>
                    <TextBlock Grid.Row="3" Text="{Binding [LocalPoint], Source={x:Static app1:LanguageManager.Instance}}"/>
                    <TextBlock Grid.Row="4" Text="{Binding [DstAddr], Source={x:Static app1:LanguageManager.Instance}}"/>
                    <TextBlock Grid.Row="5" Text="{Binding [DstEd], Source={x:Static app1:LanguageManager.Instance}}"/>

                    <TextBox Grid.Column="1" Grid.Row="0" Text="{Binding Key}"/>
                    <!--<CheckBox Grid.Column="1" Grid.Row="1" IsChecked="{Binding IsOpen}"/>-->
                    <TextBox Grid.Column="1" Grid.Row="2" Text="串口调试1"/>
                    <TextBox Grid.Column="1" Grid.Row="3" Text="串口调试1"/>
                    <TextBox Grid.Column="1" Grid.Row="4" Text="串口调试1"/>
                    <TextBox Grid.Column="1" Grid.Row="5" Text="串口调试1"/>

                </Grid>
            </GroupBox>

            <GroupBox Grid.Row="1" Grid.Column="0" Header="{Binding [SendData], Source={x:Static app1:LanguageManager.Instance}}">
                <TextBox Text="{Binding SendStr}" TextWrapping="Wrap" VerticalContentAlignment="Top" AcceptsReturn="True"/>
            </GroupBox>
            <GroupBox Grid.Row="1" Grid.Column="1" Header="{Binding [RecvData], Source={x:Static app1:LanguageManager.Instance}}">
                <TextBox Text="{Binding RecvStr}" TextWrapping="Wrap" VerticalContentAlignment="Top" AcceptsReturn="True"/>
            </GroupBox>
            <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="10,0" HorizontalAlignment="Left">
                <Button Content="{Binding [Send], Source={x:Static app1:LanguageManager.Instance}}" Width="60" Height="24" Margin="10,0" Click="SendStr_Click"/>
                <Button Content="{Binding [Clear2], Source={x:Static app1:LanguageManager.Instance}}" Width="60" Height="24" Margin="10,0" Click="CleanStr_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
