<Window x:Class="LCD.View.CustomView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LCD.View"
        xmlns:app1="clr-namespace:LCD"
        xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
        xmlns:Tree="wpf"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Title="{Binding [CustomTemplate], Source={x:Static app1:LanguageManager.Instance}}" Height="850" Width="1300">
    <Window.Resources>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="10"/>
        </Grid.RowDefinitions>
        <WrapPanel VerticalAlignment="Center" FlowDirection="RightToLeft">
            <Image Source="../Image/head.png"></Image>
            <Label Content="{Binding [CustomTemplate], Source={x:Static app1:LanguageManager.Instance}}"  FontSize="20" VerticalAlignment="Center"></Label>
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="2"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="0" >

                        <WrapPanel Grid.Row="0" 
            VerticalAlignment="Center"
                       Grid.Column="0">

                            <Label Content="{Binding [TemplateType], Source={x:Static app1:LanguageManager.Instance}}" 
            Foreground="Black"
            FontSize="16"
            FontWeight="Bold"
                   HorizontalAlignment="Left" 
                   Height="30" Margin="5,0,0,0" 
                   VerticalAlignment="Center" 
                   Width="75"/>


                            <ComboBox Height="24" 
                            VerticalAlignment="Center"
                      Margin="10,0,0,0" 
                      FontSize="16"
                      FontWeight="Bold"
                      Foreground="#07345A"
                      SelectionChanged="comboBoxType_SelectionChanged"
                      SelectedIndex="0"
                      Name="comboBoxType" 
                      Width="150" >
                                <ComboBoxItem>01-Point</ComboBoxItem>
                                <ComboBoxItem>02-Response</ComboBoxItem>
                                <ComboBoxItem>03-Spectrum</ComboBoxItem>
                                <ComboBoxItem>05-CrossTalk</ComboBoxItem>
                                <!--<ComboBoxItem>04-Flicker</ComboBoxItem>
                                <ComboBoxItem>05-CrossTalk</ComboBoxItem>
                                <ComboBoxItem>06-ACR</ComboBoxItem>-->
                                <ComboBoxItem>07-warmup</ComboBoxItem>
                                <ComboBoxItem>08-TCO</ComboBoxItem>
                            </ComboBox>


                            <!--<Label Content="模板名称" 
                            VerticalAlignment="Center"
                   HorizontalAlignment="Left" 
                   FontWeight="Bold"
                   FontSize="16"
                   Name="tempName"
                   Foreground="Black"
                   Height="30" Margin="5,0,0,0" 
                   Width="75"/>-->

                            <!--<TextBox Height="24" 
                     HorizontalAlignment="Left" 
                     FontSize="14"
                     Foreground="#07345A"
                     BorderThickness="1"
                     Name="textTmpName" 
                     Width="240" />
                            <Button Background="White"
                            Click="OnBnClickedReName"
                                    BorderBrush="Transparent" Content="重命名"></Button>-->

                            <!--<TextBox Height="28"   
                     Name="texttempPath" 
                     FontWeight="Bold"
                     Foreground="#07345A"
                     FontSize="16"
                     VerticalAlignment="Center" 
                     Width="5" Visibility="Hidden" />-->


                            <Button  Height="40" 
                        Name="buttonAdd" 
                        Click="OnBnClickedAddTemplate"
                        FontWeight="Bold"
                        VerticalAlignment="Center" 
                        Margin="30,0,0,0"
                        BorderBrush="Transparent"
                        IsEnabled="True"
                        Background="Transparent"
                        HorizontalAlignment="Right" 
                        Width="40" >
                                <svgc:SvgViewbox Source="..\Image\add.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
                            </Button>



                            <Button  Height="40" 
                        Name="buttonDelete" 
                        Click="OnBnClickedDelete"
                        FontWeight="Bold"
                        VerticalAlignment="Center" 
                        Margin="10,0,0,0"
                        BorderBrush="Transparent"
                        IsEnabled="True"
                        Background="Transparent"
                        HorizontalAlignment="Right" 
                        Width="40" >
                                <svgc:SvgViewbox Source="..\Image\sub.svg" 
                                                 IsHitTestVisible="False"></svgc:SvgViewbox>
                            </Button>

                            <Button  Height="40" 
                            Name="buttonImport"
                            Content="导入"
                            Click="OnBnClickedImport"
                            FontWeight="Bold"
                            VerticalAlignment="Center" 
                            Margin="10,0,0,0"
                            BorderBrush="Transparent"
                            IsEnabled="True"                     
                            HorizontalAlignment="Right" 
                            Foreground="White" Background="#FF50A0FF"
                            Width="40" >
                            </Button>



                        </WrapPanel>
                    </Border>
                    <!--<Button Content="模板编辑" Height="23" HorizontalAlignment="Left" Margin="187,156,0,0" Name="buttonModify" VerticalAlignment="Top" Width="91" Click="btnEditTmp_Click" Visibility="Hidden" />-->
                    <!--<Button Content="添加模板" Height="23" Margin="28,156,0,0" Name="buttonAdd" VerticalAlignment="Top" Click="btnAddTemp_Click" 
                IsEnabled="True"
                        HorizontalAlignment="Left" Width="75" />-->
                </Grid>
                <Grid Grid.Row="1" Background="White">
                    <Border Grid.Row="0" >

                        <WrapPanel Grid.Row="0" 
            VerticalAlignment='Center'
                       Grid.Column="0" FlowDirection="LeftToRight">

                            <Label Content="{Binding [ProductThick], Source={x:Static app1:LanguageManager.Instance}}"
                                   Height="30"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Bottom" />
                            <TextBox Width="100"
                                     Height="30" x:Name="ProductHeight" />

                            <Button  Height="30" 
                                 Name="buttonChange"
                                 Content="修正"
                                 Click="OnBnClickedChange"
                                 FontWeight="Bold"
                                 VerticalAlignment="Center" 
                                 Margin="20,0,0,0"
                                 BorderBrush="Transparent"
                                 IsEnabled="True"                     
                                 HorizontalAlignment="Right" 
                                 Foreground="White" Background="#FF50A0FF"
                                 Width="50" >
                            </Button>

                            <Button  
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Click="OnBnClickedAutoCreate"
                    Height="30" 
                     Name="AutoCreate" 
                     Width="40" 
                     Margin="700,0,0,0"
                    Visibility="Visible" >

                                <svgc:SvgViewbox Source="..\Image\edit.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
                            </Button>



                            <Button  Height="30" 
                        Name="buttonAdddata" 
                        Click="OnBnClickedAddIndex"
                        FontWeight="Bold"
                        VerticalAlignment="Center" 
                        Margin="20,0,0,0"
                        BorderBrush="Transparent"
                        IsEnabled="True"
                        Background="Transparent"
                        HorizontalAlignment="Right" 
                        Width="30" >
                                <svgc:SvgViewbox Source="..\Image\add_data.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
                            </Button>



                            <Button  Height="30" 
                        Name="buttonDeletedata" 
                        Click="OnBnClickedDeleIndex"
                        FontWeight="Bold"
                        VerticalAlignment="Center" 
                        Margin="20,0,0,0"
                        BorderBrush="Transparent"
                        IsEnabled="True"
                        Background="Transparent"
                        HorizontalAlignment="Right" 
                        Width="30" >
                                <svgc:SvgViewbox Source="..\Image\sub_data.svg" 
                                                 IsHitTestVisible="False"></svgc:SvgViewbox>
                            </Button>



                        </WrapPanel>
                    </Border>
                </Grid>
                <Border Grid.Row="2" Background="LightGray"
                BorderThickness="2"
                        CornerRadius="5"></Border>


                <Grid Name="gridMain" Grid.Row="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="380"/>
                            <ColumnDefinition Width="65*"/>
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" 
                                BorderBrush="LightGray"
                                BorderThickness="2"
                                CornerRadius="8" Margin="5">
                            <Grid Name="gridLeftColumn" Grid.Row="0" Grid.Column="0">

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="10*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{Binding [SelectAll], Source={x:Static app1:LanguageManager.Instance}}" Click="Btn_select_all" Width="75" Height="40" Margin="20,0,0,0"/>
                                        <Button Content="{Binding [SelectReverse], Source={x:Static app1:LanguageManager.Instance}}" Click="Btn_select_reverse" Width="75" Height="40" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <ListBox Name="mylist" SelectionChanged="mylist_SelectionChanged">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <WrapPanel Margin="4">
                                                    <CheckBox
                                                MouseRightButtonDown="CheckBox_MouseRightButtonDown"
                                                FontSize="14"
                                                Width="20"
                                                          IsChecked="{Binding IsSelected}" Focusable="True" 
                                                          />
                                                    <TextBlock Width="180" Text="{Binding Name}" >
                                                    </TextBlock>
                                                    <TextBlock Width="40" Text="{Binding Type}" >
                                                    </TextBlock>
                                                    <Button Content="{Binding [Rename], Source={x:Static app1:LanguageManager.Instance}}" Click="OnBnClickedReName" BorderBrush="Transparent" Margin="10,0,0,0" Background="Transparent"></Button>
                                                    <Button Content="{Binding [Delete], Source={x:Static app1:LanguageManager.Instance}}" BorderBrush="Transparent" Click="OnBnClickedDelete" Margin="10,0,0,0" Background="Transparent"></Button>
                                                </WrapPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="复制" Click="Copy_Click"/>
                                                <MenuItem Header="重命名" Click="Rename_Click"/>
                                                <MenuItem Header="删除" Click="Delete_Click"/>
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                    </ListBox>
                                </Grid>

                            </Grid>
                        </Border>
                        <GridSplitter Width="5"></GridSplitter>

                        <Border Grid.Row="0" 
                                Grid.Column="1" 
                                Margin="5"
                                BorderBrush="Gray" 
                                BorderThickness="2" 
                                CornerRadius="8">
                            <DataGrid Name="mydata" 
                                      LoadingRow="mydata_LoadingRow"   CanUserAddRows="false" Grid.Row="0" Grid.Column="1">
                            </DataGrid>
                        </Border>

                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="3*"/>
                                <RowDefinition Height="2*"/>
                                <RowDefinition Height="3*"/>
                                <RowDefinition Height="5*"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition />
                                    <RowDefinition />
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Row="0" 
                                        Grid.Column="1"
                                        BorderBrush="Transparent"
                                        Height="40"
                                        Width="40"
                                        x:Name="btnUP"
                                        Background="Transparent">
                                    <svgc:SvgViewbox Source="../Image/up.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button Grid.Row="1"
                                        x:Name="btnLeft" Background="Transparent"
                                        Height="40" Width="40" BorderBrush="Transparent"
                                        >
                                    <svgc:SvgViewbox Source="../Image/left.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button  Grid.Row="1"
                                         Grid.Column="1"
                                         x:Name="btnOk"
                                         Width="40"
                                         Height="40"
                                         Click="BtnOk_OnClick"
                                         Background="Transparent"
                                         BorderBrush="Transparent">

                                    <svgc:SvgViewbox Source="..\Image\zero.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button Grid.Row="1"
                                        Grid.Column="2"
                                        Height="40"
                                        Width="40"
                                        BorderBrush="Transparent"
                                        Background="Transparent"
                                        x:Name="btnRight">
                                    <svgc:SvgViewbox Source="../Image\right.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button Grid.Row="2"
                                        Grid.Column="1"
                                        Height="40"
                                        Width="40"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        x:Name="btnDown">
                                    <svgc:SvgViewbox Source="..\Image\down.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button  Grid.Row="0"
                                         Grid.Column="2"
                                         Height="40"
                                         Width="40"
                                         BorderBrush="Transparent"
                                         Background="Transparent"
                                         x:Name="btnIn">

                                    <svgc:SvgViewbox Source="..\Image\sort-up.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button Grid.Row="2"
                                        Grid.Column="2"
                                        Width="40"
                                        Height="40"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        x:Name="btnOut">
                                    <svgc:SvgViewbox Source="..\Image\sort-down.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button  Grid.Row="1"
                                         Grid.Column="4"
                                         Height="40"
                                         Width="40"
                                         Background="Transparent"
                                         BorderBrush="Transparent"
                                         Name="btnURight">
                                    <svgc:SvgViewbox Source="..\Image\acrotate.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button Grid.Row="1"
                                        Grid.Column="3"
                                        Height="40"
                                        Width="40"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        x:Name="btnULeft">

                                    <svgc:SvgViewbox Source="..\Image\cwrotate.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button Grid.Row="0"
                                        Grid.Column="4"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        Height="40"
                                        Width="40"
                                        x:Name="btnVRight">

                                    <svgc:SvgViewbox Source="..\Image\rotate-left.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                                <Button Grid.Row="0"
                                        Grid.Column="3"
                                        Height="40"
                                        Width="40"
                                        BorderBrush="Transparent"
                                        Background="Transparent"
                                        x:Name="btnVLeft">

                                    <svgc:SvgViewbox Source="..\Image\rotate-right.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                            </Grid>
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                                <WrapPanel Background="White"
                                           Orientation="Horizontal"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left">
                                    <Label Content="{Binding [XAxis], Source={x:Static app1:LanguageManager.Instance}}"
                                           Width="30"
                                           Foreground="Black"></Label>
                                    <TextBlock Width="80"
                                               FontSize="16"
                                               Name="XPos"
                                               Foreground="Black"></TextBlock>
                                </WrapPanel>
                                <WrapPanel Background="White"
                                           Grid.Row="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left">
                                    <Label Content="{Binding [YAxis], Source={x:Static app1:LanguageManager.Instance}}"
                                           Width="30"
                                           Foreground="Black"></Label>
                                    <TextBlock Width="80"
                                               FontSize="16"
                                               Name="YPos"
                                               Foreground="Black"></TextBlock>
                                </WrapPanel>
                                <WrapPanel Background="White"
                                           Grid.Row="2"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left">
                                    <Label Content="{Binding [ZAxis], Source={x:Static app1:LanguageManager.Instance}}"
                                           Width="30"
                                           Foreground="Black"></Label>
                                    <TextBlock Width="80"
                                               FontSize="16"
                                               Name="ZPos"
                                               Foreground="Black"></TextBlock>
                                </WrapPanel>
                                <WrapPanel Background="White"
                                           Grid.Row="0"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left">
                                    <Label Content="{Binding [UAxis], Source={x:Static app1:LanguageManager.Instance}}"
                                           Width="30"
                                           Foreground="Black"></Label>
                                    <TextBlock Width="80"
                                               FontSize="16"
                                               Name="UPos"
                                               Foreground="Black"></TextBlock>
                                </WrapPanel>
                                <WrapPanel Background="White"
                                           Grid.Row="1"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left">
                                    <Label Content="{Binding [VAxis], Source={x:Static app1:LanguageManager.Instance}}"
                                           Width="30"
                                           Foreground="Black"></Label>
                                    <TextBlock Width="80"
                                               FontSize="16"
                                               Name="VPos"
                                               Foreground="Black"></TextBlock>
                                </WrapPanel>
                                <WrapPanel Background="White"
                                           Grid.Row="2"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left">
                                    <Label Content="Ball"
                                           Width="30"
                                           Foreground="Black"></Label>
                                    <TextBlock Width="80"
                                               FontSize="16"
                                               Name="BallPos"
                                               Foreground="Black"></TextBlock>
                                </WrapPanel>
                            </Grid>

                            <ListBox Name="mylist1" Grid.Row="2" >
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <WrapPanel Margin="4">
                                            <TextBlock Width="20"
                                                       Text="{Binding Name2}">
                                            </TextBlock>
                                            <TextBlock Width="180"
                                                       Text="{Binding Name1}">
                                            </TextBlock>
                                        </WrapPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="40"/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                                    <Label Content="{Binding [TestStd], Source={x:Static app1:LanguageManager.Instance}}" Width="90"></Label>
                                </WrapPanel>

                                <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                                    <CheckBox Content="L:" x:Name="Lcheck"
                                    IsChecked="False"
                                    Margin="40,0,0,0"
                                    VerticalAlignment="Center" Width="50"></CheckBox>
                                    <TextBox x:Name="Lmin" Width="60" 
                                     Text=""
                                     VerticalAlignment="Center" FontSize="14"></TextBox>
                                    <Label Content="&lt;" Width="20" VerticalAlignment="Center" />
                                    <Label Content="L"></Label>
                                    <Label Content="&lt;" Width="20" />
                                    <TextBox x:Name="Lmax" Width="60" 
                                    Text=""
                                    VerticalAlignment="Center" FontSize="14"></TextBox>
                                </WrapPanel>


                                <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                                    <CheckBox x:Name="Xcheck" Content="x:" VerticalAlignment="Center" 
                                     Margin="40,0,0,0"
                                     IsChecked="False"
                                     Width="50"></CheckBox>
                                    <TextBox x:Name="xmin" Width="60"
                                        Text=""
                                     VerticalAlignment="Center" FontSize="14"></TextBox>
                                    <Label Content="&lt;" Width="20" VerticalAlignment="Center" />
                                    <Label Content="x"></Label>
                                    <Label Content="&lt;" Width="20" />
                                    <TextBox x:Name="xmax" Width="60"
                                    Text=""
                                     VerticalAlignment="Center" FontSize="14"></TextBox>
                                </WrapPanel>



                                <WrapPanel Grid.Row="3" VerticalAlignment="Center">
                                    <CheckBox x:Name="Ycheck" Content="y:"
                                     Margin="40,0,0,0"
                                     IsChecked="False"
                                     VerticalAlignment="Center" Width="50"></CheckBox>
                                    <TextBox x:Name="ymin" Width="60"
                                    Text=""
                                    VerticalAlignment="Center" FontSize="14"></TextBox>
                                    <Label Content="&lt;" Width="20" VerticalAlignment="Center" />
                                    <Label Content="y"></Label>
                                    <Label Content="&lt;" Width="20" />
                                    <TextBox x:Name="ymax" Width="60" 
                                    Text=""
                                    VerticalAlignment="Center" FontSize="14"></TextBox>
                                </WrapPanel>

                                <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                                    <CheckBox  x:Name="Balancechk" Content="{Binding [ConformityReq], Source={x:Static app1:LanguageManager.Instance}}"
                                     Margin="40,0,0,0"
                                     IsChecked="False"
                                     VerticalAlignment="Center" Width="150"></CheckBox>
                                    <TextBox x:Name="balancemin" Width="60"
                                     Text=""
                                     VerticalAlignment="Center" FontSize="14"></TextBox>
                                    <Label Content="%" />
                                </WrapPanel>

                                <WrapPanel Grid.Row="5" VerticalAlignment="Center">
                                    <Label Width="90" Content="{Binding [UnFitColor], Source={x:Static app1:LanguageManager.Instance}}" Margin="40,0,0,0" />
                                    <Rectangle x:Name="RecColor" Fill="Red" Width="100" MouseLeftButtonDown="Color_select"/>
                                </WrapPanel>

                                <WrapPanel Grid.Row="6" VerticalAlignment="Center" Height="40">
                                    <Button Width="120" Content="{Binding [Save], Source={x:Static app1:LanguageManager.Instance}}"  Click="BtnOnSave_click" Background="White" FontWeight="Bold" Height="30" Margin="80,0,0,0"></Button>
                                </WrapPanel>

                            </Grid>
                        </Grid>
                    </Grid>
                    <!--<GridSplitter Width="1" IsEnabled="False"></GridSplitter>-->
                </Grid>
            </Grid>

        </Grid>

        <!--定义确定按钮实现长度位置-->
        <Grid Grid.Row="2">
            <WrapPanel VerticalAlignment="Center"  HorizontalAlignment="Center">
                <Button Width="120" Content="{Binding [Load], Source={x:Static app1:LanguageManager.Instance}}" Background="White" FontWeight="Bold" Margin="0,0,50,0" Click="LoadConfiger"></Button>
                <Button Width="120" Content="{Binding [SaveAs], Source={x:Static app1:LanguageManager.Instance}}" Background="White" 
                Click="OnBnClickedSaveAs"
                        FontWeight="Bold" Margin="0,0,50,0"></Button>
                <Button Width="120" Content="{Binding [OK], Source={x:Static app1:LanguageManager.Instance}}"  Click="OnBnClickedEnsure" Background="White" FontWeight="Bold" Height="30" ></Button>
            </WrapPanel>
        </Grid>
    </Grid>
</Window>

