<UserControl x:Class="LCD.View.CamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LCD.View"
             xmlns:app1="clr-namespace:LCD"
             mc:Ignorable="d" 
                    xmlns:wf="clr-namespace:System.Windows.Forms;assembly=System.Windows.Forms"
     xmlns:airspace="clr-namespace:Microsoft.DwayneNeed.Interop;assembly=Microsoft.DwayneNeed"
             Background="Black"
             Loaded="UserControl_Loaded"
             d:DesignHeight="450" d:DesignWidth="800" DataContext="{Binding Mode=OneWay, RelativeSource={RelativeSource Self}}">
    <Grid SizeChanged="Grid_SizeChanged">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Name="grid0">

                <Image  Source="{Binding wbBitmap}"
                        Name="pictureHost"
                        Visibility="Visible"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                </Image>

                <Border x:Name="leftline" Background="Red"
                        Margin="{Binding LeftMargin}"
                        HorizontalAlignment="Left"
                        SnapsToDevicePixels="True"
                        Width="2" />
                <Border x:Name="topline" Background="Red"
                        Margin="{Binding TopMargin}"
                        VerticalAlignment="Top"
                        SnapsToDevicePixels="True"
                        Height="2" />

            </Grid>
            <Grid Grid.Row="1">
                <WrapPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" >
                    <Label Content="{Binding [CamerPara1], Source={x:Static app1:LanguageManager.Instance}}"
                           Width="90"
                           Background="Black"
                           Foreground="White"
                           Margin="0,0,0,0"
                           FontSize="14"></Label>
                    <Label Content="{Binding [Exposure1], Source={x:Static app1:LanguageManager.Instance}}"
                           Background="Black"
                           Foreground="White"
                           Width="80"
                           FontSize="14"></Label>
                    <ScrollBar Orientation="Horizontal"
                               Width="420"
                               Background="Black"
                               Foreground="White"
                               Name="ScrollBar"
                               Maximum="800000"
                               ValueChanged="ScrollBar_OnValueChanged" MouseLeave="ScrollBar_OnMouseLeave"></ScrollBar>
                    <!--<TextBox Name="Cam" Width="80" FontSize="14" VerticalAlignment="Center">8000</TextBox>-->
                    <!--<Label Content="ms" Width="50" FontSize="14"></Label>-->
                </WrapPanel>
            </Grid>
            <!--23*   {Binding Colu1}     {Binding Row}    17*-->

            <!--<Grid Grid.Column="0" Grid.Row="0" Background="Transparent">
                <Grid Height="{Binding Row}" Width="{Binding Colu1}"/>
            </Grid>-->
            

        </Grid>

    </Grid>
</UserControl>
