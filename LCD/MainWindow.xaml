                <MenuItem Header="{Binding [LoadingPos], Source={x:Static local:LanguageManager.Instance}}" Click="MenuItem_OnClickup"/>
                <MenuItem Header="{Binding [MoveDebug], Source={x:Static local:LanguageManager.Instance}}" Click="MenuItem_OnClickDebug"/>
            </MenuItem>
            <!--<MenuItem Header="测量（M）">
                <MenuItem Header="单点测量"></MenuItem>
                <MenuItem Header="多点测量"></MenuItem>
            </MenuItem>-->

            <!--<MenuItem Header="模板（T）">
                <MenuItem Header="5点模板" Click="OnBnClicked5PointView"></MenuItem>
                <MenuItem Header="9点模板" Click="OnBnClicked9PointView"></MenuItem>
                <MenuItem Header="13点模板" Click="OnBnClicked13PointView"></MenuItem>
                -->
            <!--<MenuItem Header="点位模板" Click="OnBnClickedCustomTemplate"></MenuItem>
                <MenuItem Header="响应模板" Click="OnBnClickedResponseTemplate"></MenuItem>
                <MenuItem Header="自定义模板组" Click="OnBnClickedCustomView" ></MenuItem>-->
            <!--
            </MenuItem>-->

            <!--<MenuItem Header="报表（R）">
                <MenuItem Header="单次报表"></MenuItem>
                <MenuItem Header="多次报表"></MenuItem>
            </MenuItem>-->
            <MenuItem Header="{Binding [Helph], Source={x:Static local:LanguageManager.Instance}}">
