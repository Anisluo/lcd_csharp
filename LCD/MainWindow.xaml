            <Button Visibility="Collapsed" Content="停止" Margin="1" Style="{StaticResource ButtonBaseStyle}" hc:IconElement.Geometry="{StaticResource StopGeometry}" hc:IconElement.Height="12" Foreground="White" Background="DarkRed"/>


