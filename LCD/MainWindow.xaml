                <MenuItem Header="{Binding [OpManual], Source={x:Static local:LanguageManager.Instance}}"></MenuItem>
                <MenuItem Header="{Binding [DeviceSelfCheck], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickedSelfCheck"></MenuItem>
            </MenuItem>
        </Menu>

        <TextBlock Visibility="Collapsed" Grid.Row="1" Margin="0,0,360,0" VerticalAlignment="Center" Width="120" FontSize="24" Background="Red" TextAlignment="Center" Text="正常" HorizontalAlignment="Right"/>

        <WrapPanel Grid.Row="1" VerticalAlignment="Center">
            <Button  Width="30" Height="28" Margin="10,0,0,0" BorderBrush="Transparent" Background="Transparent" BorderThickness="0" Click="OnBnClickedSwitchUser" VerticalAlignment="Center" >
                <svgc:SvgViewbox Source="Image\user.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
            </Button>

            <Button  Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="OnBnClickedStop" VerticalAlignment="Center" >
                <svgc:SvgViewbox Source="Image\run.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
            </Button>


            <Button  Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="OnBnClickedHistory" VerticalAlignment="Center" >
                <svgc:SvgViewbox Source="Image\Stop.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
            </Button>

            <Button  Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" Click="OnBnClickedHistory" VerticalAlignment="Center" >
                <svgc:SvgViewbox Source="Image\history.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
            </Button>

            <Button  Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="OnBnClickedHistory" VerticalAlignment="Center" >
                <svgc:SvgViewbox Source="Image\template.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
            </Button>

            <!--<Button  Width="30" Height="28" Margin="0,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" FontSize="16" Content="2°" Click="OnBnClickedHistory" VerticalAlignment="Center"/>
            <Button  Width="30" Height="28" Margin="2,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" FontSize="16" Content="1°" Click="OnBnClickedHistory" VerticalAlignment="Center" />
            <Button  Width="30" Height="28" Margin="2,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" FontSize="16" Content="0.2°" Click="OnBnClickedHistory" VerticalAlignment="Center"/>
            <Button  Width="30" Height="28" Margin="2,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" FontSize="16" Content="0.1°" Click="OnBnClickedHistory" VerticalAlignment="Center"/>-->
            
            <Button Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="OnBnClickedClear" VerticalAlignment="Center" >
                <svgc:SvgViewbox Source="Image\clear.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
            </Button>

            <StackPanel x:Name="ViewAngleBtns" Orientation="Horizontal">
                <Button x:Name="ViewAngle2" Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="OnBnClickedView2" VerticalAlignment="Center" >
                    <svgc:SvgViewbox Source="Image\2.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
                </Button>
                <Button  Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="OnBnClickedView1" VerticalAlignment="Center" >
                    <svgc:SvgViewbox Source="Image\1.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
                </Button>
                <Button  Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="OnBnClickedView02" VerticalAlignment="Center" >
                    <svgc:SvgViewbox Source="Image\02.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
                </Button>
                <Button  Width="30" Height="28" Margin="10,0,0,0" Background="Transparent" BorderBrush="Transparent" BorderThickness="0" Click="OnBnClickedView01" VerticalAlignment="Center" >
                    <svgc:SvgViewbox Source="Image\01.svg" IsHitTestVisible="False"></svgc:SvgViewbox>
                </Button>
            </StackPanel>

