    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="35"/>
            <RowDefinition/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <WrapPanel Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right">
            <Image Source="Image/head.png"/>
        </WrapPanel>

        <Menu  HorizontalAlignment="Left" Background="Transparent" VerticalAlignment="Center">
            <MenuItem Header="{Binding [FileF], Source={x:Static local:LanguageManager.Instance}}">
                <MenuItem Header="{Binding [Open], Source={x:Static local:LanguageManager.Instance}}" Click="Open_OnClick"></MenuItem>
                <MenuItem Header="{Binding [Close], Source={x:Static local:LanguageManager.Instance}}" Click="Close_Click"></MenuItem>
                <!--<MenuItem Header="导出CSV"></MenuItem>-->
                <MenuItem Header="{Binding [History], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickedHistory"></MenuItem>
                <!--<MenuItem Header="图像"></MenuItem>-->
            </MenuItem>
            <MenuItem x:Name="MenuPara" Header="{Binding [ParaP], Source={x:Static local:LanguageManager.Instance}}">
                <MenuItem Header="{Binding [DeviceSet], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickedDevice"></MenuItem>
                <MenuItem Name="Viewangle" Header="{Binding [ViewpointSw], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickedFdl"></MenuItem>
                <MenuItem Name="MPcItemMenuItem" Header="{Binding [PlatformSet], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickMPC"></MenuItem>
                <MenuItem Header="{Binding [SportMode], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickMoveStyle"></MenuItem>
                <MenuItem Header="{Binding [CameraSet], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickCamera"></MenuItem>
                <MenuItem Header="{Binding [DeviceResponseSet], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickedResp"></MenuItem>
                <MenuItem Header="{Binding [PGSet], Source={x:Static local:LanguageManager.Instance}}" Click="OnBnClickedPGView"></MenuItem>
                <MenuItem Header="{Binding [PowerSet], Source={x:Static local:LanguageManager.Instance}}"
