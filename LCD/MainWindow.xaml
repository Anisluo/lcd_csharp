                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </ToggleButton>


                                <ToggleButton  FontSize="20"
                                               FontWeight="Bold"
                                               BorderBrush="Transparent"
                                               Background="Transparent"
                                               Name="SpeedMedium_2"
                                               Click="OnBnClickedSpeedMedium_2"
                                               Height="25"
                                               Width="25">
                                    <svgc:SvgViewbox Source="Image\speed2.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </ToggleButton>

                                <ToggleButton  FontSize="20"
                                               FontWeight="Bold"
                                               BorderBrush="Transparent"
                                               Background="Transparent"
                                               Name="SpeedHigh_2"
                                               Click="OnBnClickedSpeedHigh_2"
                                               Height="25"
                                               Width="25">
                                    <svgc:SvgViewbox Source="Image\speed3.svg"
                                                     IsHitTestVisible="False"></svgc:SvgViewbox>
                                </ToggleButton>
                            </WrapPanel>
                        </Grid>

                        <Grid Grid.Column="3">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <WrapPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button x:Name="TempButton" Background="White" Width="90" Height="28" Click="OnBnClickedSelfTemplate" FontWeight="Bold" Content="{Binding [TestTemplate], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource ButtonBaseStyle}"/>
                            </WrapPanel>

                            <WrapPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button x:Name="SingleButton" Background="White" Width="90" Click="OnBnClickReadSingleData" FontWeight="Bold" Height="28" Content="{Binding [Test1Point], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource ButtonBaseStyle}"/>
                            </WrapPanel>

                            <WrapPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button x:Name="SprectrumButon" Width="90" FontWeight="Bold" Height="28" Background="White" Click="OnBnClickSpectrumSingleData" Content="{Binding [TestSpectral], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource ButtonBaseStyle}"/>
                            </WrapPanel>

                            <WrapPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button x:Name="ResetButton" Width="90" Content="{Binding [ResetMsg], Source={x:Static local:LanguageManager.Instance}}" Click="Button_Click" Margin="1" Style="{StaticResource ButtonBaseStyle}" hc:IconElement.Geometry="{StaticResource ResetGeometry}" hc:IconElement.Height="12" Foreground="White" Background="#FF50A0FF"/>
                            </WrapPanel>
                        </Grid>


                        <Grid Grid.Column="4">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <WrapPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button x:Name="StartTestButton" FontSize="20" 
                                FontWeight="Bold"
                                Background="Green"
                                Click="OnBnClickedStartRun"
                                        Height="50" Width="50">
                                    <svgc:SvgViewbox 
                                        Source="Image\run.svg" 
                                        IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                            </WrapPanel>

                            <WrapPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Button  FontSize="20" 
                                FontWeight="Bold"
                                Click="OnBnClickedFstStop"
                                Background="Red"
                                        Height="50" Width="50">
                                    <svgc:SvgViewbox 
                                        Source="Image\Stop.svg" 
                                        IsHitTestVisible="False"></svgc:SvgViewbox>
                                </Button>
                            </WrapPanel>
                        </Grid>


                        <Grid Grid.Column="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="AUto"/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>


                            <WrapPanel Background="Black" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Label Content="{Binding [XAxis], Source={x:Static local:LanguageManager.Instance}}" Foreground="White"></Label>
                                <TextBlock Width="80" FontSize="16" Name="XPos" Foreground="White" ></TextBlock>
                            </WrapPanel>


                            <WrapPanel Background="Black" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Label Content="{Binding [YAxis], Source={x:Static local:LanguageManager.Instance}}" Foreground="White"></Label>
                                <TextBlock Width="80" FontSize="16" Name="YPos" Foreground="White"></TextBlock>
                            </WrapPanel>


                            <WrapPanel Background="Black" Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Label Content="{Binding [ZAxis], Source={x:Static local:LanguageManager.Instance}}" Foreground="White"></Label>
                                <TextBlock Width="80" FontSize="16" Name="ZPos" Foreground="White"></TextBlock>
                            </WrapPanel>
                        </Grid>


                        <Grid Grid.Column="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="AUto"/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>


                            <WrapPanel Background="Black" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Label Content="{Binding [UAxis], Source={x:Static local:LanguageManager.Instance}}" Foreground="White"></Label>
                                <TextBlock Width="80" FontSize="16" Name="UPos" Foreground="White"></TextBlock>
                            </WrapPanel>


                            <WrapPanel Background="Black" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Label Content="{Binding [VAxis], Source={x:Static local:LanguageManager.Instance}}" Foreground="White"></Label>
                                <TextBlock Width="80" FontSize="16" Name="VPos" Foreground="White"></TextBlock>
                            </WrapPanel>


                            <WrapPanel Visibility="Hidden" Background="Black" Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Label Content="Ball：" Foreground="White"></Label>
                                <TextBlock Width="80" 
                                FontSize="16"
                                           Name="BallPos" 
                                           Foreground="White"></TextBlock>
                            </WrapPanel>
                        </Grid>

                        <Grid Grid.Column="7" x:Name="PowerControllerPanel">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="AUto"/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <WrapPanel  Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Label Content="{Binding [PowerControl], Source={x:Static local:LanguageManager.Instance}}" Foreground="Black"></Label>
                            </WrapPanel>

                            <WrapPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Label Width="80" Margin="5,0,0,0" Content="{Binding [VoltageSet], Source={x:Static local:LanguageManager.Instance}}" Foreground="Black"></Label>
                                <TextBox Width="80" FontSize="16" Name="VoltageSet" Foreground="Black"></TextBox>
                            </WrapPanel>

                            <WrapPanel Grid.Row="3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Label Width="80" Margin="5,0,0,0" Content="{Binding [CurrentSet], Source={x:Static local:LanguageManager.Instance}}" Foreground="Black"></Label>
                                <TextBox Width="80" FontSize="16" Name="CurrentSet" Foreground="Black"></TextBox>
                            </WrapPanel>

                            <WrapPanel Grid.Row="4" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Label Width="80" Margin="5,0,0,0" Content="{Binding [RealVoltage], Source={x:Static local:LanguageManager.Instance}}" Foreground="Black"></Label>
                                <TextBlock Width="80" FontSize="16" Name="RealVoltage" Foreground="Black"></TextBlock>
                            </WrapPanel>

                            <WrapPanel Grid.Row="5" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Label Width="80" Margin="5,0,0,0" Content="{Binding [RealCurrent], Source={x:Static local:LanguageManager.Instance}}" Foreground="Black"></Label>
                                <TextBlock Width="80" FontSize="16" Name="RealCurrent" Foreground="Black"></TextBlock>
                            </WrapPanel>

                            <WrapPanel Grid.Row="6" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Button Name="PowerOutputBtn" Width="70" Margin="5,0,0,0" FontSize="18" Content="{Binding [PowerOuput], Source={x:Static local:LanguageManager.Instance}}" Style="{StaticResource ButtonBaseStyle}"  Foreground="White" Background="#FF50A0FF"></Button>
                                <Button  Content="打开" Width="70" Margin="10,0,0,0" FontSize="18" Name="PowerBtn" Style="{StaticResource ButtonBaseStyle}"  Foreground="White" Background="#FF50A0FF"></Button>
                            </WrapPanel>

                        </Grid>


                    </Grid>
                </Grid>
            </Grid>
            <GridSplitter Width="2"  FlowDirection="LeftToRight"/>
            <Grid Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="70*"/>
                    <RowDefinition Height="40*"/>
                </Grid.RowDefinitions>
                <TabControl Margin="0,0,0,2">
                    <TabItem Header="{Binding [MonitorScreen], Source={x:Static local:LanguageManager.Instance}}">
                        <ContentControl Background="Black" Name="cam"/>
                    </TabItem>
                    <TabItem Header="{Binding [TestDevice], Source={x:Static local:LanguageManager.Instance}}">
                        <ContentControl Background="Black" Name="device"></ContentControl>
                    </TabItem>
                    <TabItem Header="{Binding [CommCheck], Source={x:Static local:LanguageManager.Instance}}">
                        <ContentControl Background="Black" Name="ecom"></ContentControl>
                    </TabItem>
                    <TabItem Header="{Binding [PGTest], Source={x:Static local:LanguageManager.Instance}}">
                        <ContentControl Background="Black"
                                        Name="PG"></ContentControl>
                    </TabItem>
                    <TabItem Header="{Binding [CrosstalkInfo], Source={x:Static local:LanguageManager.Instance}}">
                        <ContentControl Background="Black"
                         Name="CrosstalkImage">
                            <Image Source="Image\crosstalk.png" />
                        </ContentControl>
                    </TabItem>
                </TabControl>

                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="2" />

                <TabControl Grid.Row="1" x:Name="LogIndex">
                    <TabItem Header="{Binding [LogOutput], Source={x:Static local:LanguageManager.Instance}}">
                        <RichTextBox Name="xxx" TextChanged="xxx_TextChanged" VerticalScrollBarVisibility="Visible">
                            <FlowDocument Name="mylog" LineHeight="2">

                            </FlowDocument>
                        </RichTextBox>
                    </TabItem>
                    <TabItem Header="{Binding [TestContent], Source={x:Static local:LanguageManager.Instance}}" Visibility="Collapsed">
                        <TabItem.Content>
                            <ContentControl x:Name="workItem"/>
                        </TabItem.Content>
                    </TabItem>

                    <TabItem Header="{Binding [TestFlow], Source={x:Static local:LanguageManager.Instance}}">
                        <TabItem.Content>
                            <ContentControl Grid.Row="1" x:Name="workData"/>
                        </TabItem.Content>
                    </TabItem>
                </TabControl>

            </Grid>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="79*"/>
                <ColumnDefinition Width="76*"/>
            </Grid.ColumnDefinitions>
            <StatusBar Name="statusbar" Grid.ColumnSpan="2">
                <StatusBar.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                </StatusBar.Resources>
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding [XAxis], Source={x:Static local:LanguageManager.Instance}}"/>
                        <TextBlock Name="x" Text="{Binding [NotConnect], Source={x:Static local:LanguageManager.Instance}}" Foreground="DarkRed" FontSize="10"/>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding [YAxis], Source={x:Static local:LanguageManager.Instance}}" VerticalAlignment="Center"/>
                        <TextBlock Name="y" Text="{Binding [NotConnect], Source={x:Static local:LanguageManager.Instance}}" Foreground="DarkRed" FontSize="10"/>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding [ZAxis], Source={x:Static local:LanguageManager.Instance}}"/>
                        <TextBlock Name="z" Text="{Binding [NotConnect], Source={x:Static local:LanguageManager.Instance}}" Foreground="DarkRed" FontSize="10"/>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding [UAxis], Source={x:Static local:LanguageManager.Instance}}"/>
                        <TextBlock Name="u" Text="{Binding [NotConnect], Source={x:Static local:LanguageManager.Instance}}" Foreground="DarkRed" FontSize="10"/>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding [VAxis], Source={x:Static local:LanguageManager.Instance}}"/>
                        <TextBlock Name="v" Text="{Binding [NotConnect], Source={x:Static local:LanguageManager.Instance}}" Foreground="DarkRed" FontSize="10"/>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem>
                    <StackPanel Orientation="Horizontal"  x:Name="PowerControlStatus">
                        <TextBlock  Text="{Binding [ControlPowerDash], Source={x:Static local:LanguageManager.Instance}}"/>
                        <TextBlock Name="PowerControl" Text="{Binding [NotConnect], Source={x:Static local:LanguageManager.Instance}}" Foreground="DarkRed" FontSize="10"/>
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding [TestSig1], Source={x:Static local:LanguageManager.Instance}}" />
                        <TextBlock Name="TestSignal1"
                                   Text=""
                                   Foreground="DarkRed"
                                   FontSize="10" />
                    </StackPanel>
                </StatusBarItem>
                <StatusBarItem  Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding [TestSig2], Source={x:Static local:LanguageManager.Instance}}" />
                        <TextBlock Name="TestSignal2"
                                   Text="{Binding [NotConnect], Source={x:Static local:LanguageManager.Instance}}"
                                   Foreground="DarkRed"
                                   FontSize="10" />
                    </StackPanel>
                </StatusBarItem>

                <StatusBarItem x:Name="TimeCountBar" Visibility="Collapsed" >
                    <StackPanel Orientation="Horizontal">
                        <TextBlock  Text="{Binding [WarnCount], Source={x:Static local:LanguageManager.Instance}}" />
                        <TextBlock Name="TimeCount"
                        Text=""
                        Foreground="DarkRed"
                        FontSize="10" />
                    </StackPanel>
                </StatusBarItem>
                <!--<StatusBarItem>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Name="d" Text="仪器:"/>
                            <TextBlock Text="未连接" Foreground="DarkRed" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </StatusBarItem>-->
                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Name="testst" Text="{Binding [TestStatus], Source={x:Static local:LanguageManager.Instance}}"/>
                        <TextBlock Text="{Binding [Preparing], Source={x:Static local:LanguageManager.Instance}}" Foreground="DarkRed" FontSize="10"/>
                    </StackPanel>
                </StatusBarItem>
                <!--<StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Name="devst" Text="设备状态:"/>
                        <TextBlock Text="准备中" Foreground="DarkRed" FontSize="10"/>
                    </StackPanel>
                </StatusBarItem>-->
            </StatusBar>
        </Grid>
    </Grid>
</Window>
