<Application x:Class="LCD.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LCD"
             StartupUri="MainWindow.xaml">
             <!--StartupUri="MainWindow.xaml">-->
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Geometry.xaml" />
                <ResourceDictionary Source="Themes/BrushesColors.xaml" />
                <ResourceDictionary Source="Resources/TextBoxStyles.xaml" />
                <ResourceDictionary Source="Themes/Buttons.xaml" />
                <!-- Phase 6: implicit modern defaults (loaded last so they
                     win over any earlier implicit TargetType styles). -->
                <ResourceDictionary Source="Themes/ModernDefaults.xaml" />
                <!--<ResourceDictionary Source="/SciChart.Examples.ExternalDependencies;component/Resources/Styles/MergedResources.xaml" />-->
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="MyTransparent" Color="#01000000"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
